    <nav id="categoryBar" class="category-bar" aria-label="分类导航"></nav>

    <section class="main-grid">
      <div class="shelf-area">
        <div id="shelfTopScrollbar" class="shelf-top-scrollbar" aria-label="书籍栏横向拖动条" role="scrollbar">
          <div id="shelfTopScrollbarInner" class="shelf-top-scrollbar-inner"></div>
