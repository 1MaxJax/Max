<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>本地虚拟书架 Web 版｜信息资源可视化</title>
  <style>
    :root {
      --bg: #f7f3ec;
      --panel: #fffaf2;
      --card: #fffdf8;
      --wood: #a9794f;
      --wood-dark: #6f472b;
      --line: rgba(86, 63, 42, 0.18);
      --text: #2f261f;
      --muted: #796d61;
      --accent: #7755b2;
      --spectrum-red: #dd5b5b;
      --spectrum-orange: #e8a144;
      --spectrum-green: #67a96a;
      --spectrum-blue: #5d86d6;
      --spectrum-purple: #9163d8;
      --accent-soft: rgba(119, 85, 178, 0.12);
      --danger: #9b3730;
      --shadow: 0 14px 40px rgba(67, 49, 32, 0.12);
      font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      min-height: 100vh;
      color: var(--text);
      background:
        radial-gradient(circle at 12% 10%, rgba(119, 85, 178, 0.10), transparent 28%),
        radial-gradient(circle at 84% 12%, rgba(180, 118, 62, 0.14), transparent 30%),
        var(--bg);
      overflow-x: hidden;
    }

    .wave-canvas {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      z-index: 0;
      pointer-events: none;
      opacity: 0.96;
    }

    body::after {
      content: "";
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 0%, rgba(255,255,255,0.42), transparent 45%),
        linear-gradient(180deg, rgba(247,243,236,0.24), rgba(247,243,236,0.54));
    }

    button, input, select {
      font: inherit;
    }

    button {
      cursor: pointer;
      border: 0;
    }

    .app {
      position: relative;
      z-index: 1;
      width: min(1180px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 28px 0 36px;
    }

    .hero {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 18px;
      align-items: stretch;
      margin-bottom: 18px;
    }

    .hero-card, .side-card, .reader-panel, .empty-panel {
      background: rgba(255, 253, 248, 0.82);
      backdrop-filter: blur(10px);
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: var(--shadow);
    }

    .hero-card {
      padding: 24px;
      min-height: 210px;
    }

    .visual-note {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 12px;
      color: var(--muted);
      font-size: 13px;
    }

    .visual-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 6px var(--accent-soft);
    }

    .spectrum-note {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 14px;
    }

    .spectrum-pill {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 10px;
      border-radius: 999px;
      font-size: 12px;
      border: 1px solid rgba(55, 37, 22, 0.10);
      background: rgba(255,255,255,0.64);
      color: var(--muted);
    }

    .spectrum-pill::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: currentColor;
      box-shadow: 0 0 0 4px color-mix(in srgb, currentColor 18%, white);
    }

    .spectrum-pill.red { color: var(--spectrum-red); }
    .spectrum-pill.orange { color: var(--spectrum-orange); }
    .spectrum-pill.green { color: var(--spectrum-green); }
    .spectrum-pill.blue { color: var(--spectrum-blue); }
    .spectrum-pill.purple { color: var(--spectrum-purple); }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--accent);
      background: var(--accent-soft);
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 13px;
      margin-bottom: 14px;
    }

    h1 {
      margin: 0 0 10px;
      line-height: 1.02;
      letter-spacing: -0.04em;
    }

    .prism-title {
      display: inline-flex;
      align-items: flex-end;
      gap: clamp(6px, 1vw, 12px);
      font-size: clamp(54px, 11vw, 108px);
      font-weight: 800;
      user-select: none;
      filter: drop-shadow(0 6px 18px rgba(67, 49, 32, 0.08));
    }

    .prism-letter {
      position: relative;
      display: inline-block;
      cursor: pointer;
      user-select: none;
      z-index: 2;
      pointer-events: auto;
      padding: 0 2px 6px;
      border-radius: 18px;
      transition: transform .42s cubic-bezier(.2,.9,.2,1.28), margin .42s ease, filter .42s ease, text-shadow .42s ease, opacity .28s ease;
      transform-origin: center bottom;
      will-change: transform;
      text-shadow: 0 2px 0 rgba(255,255,255,0.4);
    }

    .prism-letter:hover {
      opacity: 0.94;
      filter: saturate(1.08) brightness(1.04);
    }

    .prism-letter:focus-visible {
      outline: none;
      filter: saturate(1.10) brightness(1.08);
    }

    .prism-letter::after {
      content: attr(data-letter);
      position: absolute;
      left: 0;
      top: 0;
      opacity: 0.14;
      filter: blur(10px);
      transform: translateY(10px);
      pointer-events: none;
    }

    .prism-letter[data-color="red"] { color: var(--spectrum-red); }
    .prism-letter[data-color="orange"] { color: var(--spectrum-orange); }
    .prism-letter[data-color="green"] { color: var(--spectrum-green); }
    .prism-letter[data-color="blue"] { color: var(--spectrum-blue); }
    .prism-letter[data-color="purple"] { color: var(--spectrum-purple); }

    .prism-title.active-0 .prism-letter[data-index="0"],
    .prism-title.active-1 .prism-letter[data-index="1"],
    .prism-title.active-2 .prism-letter[data-index="2"],
    .prism-title.active-3 .prism-letter[data-index="3"],
    .prism-title.active-4 .prism-letter[data-index="4"] {
      transform: translateY(-8px) scale(1.28) rotate(-4deg);
      margin-left: 6px;
      margin-right: 12px;
      filter: saturate(1.1) brightness(1.05);
      text-shadow: 0 0 14px rgba(255,255,255,0.82), 0 6px 18px rgba(67, 49, 32, 0.10);
    }

    .prism-letter[data-active="true"] {
      text-shadow:
        0 0 18px color-mix(in srgb, currentColor 64%, transparent),
        0 0 34px color-mix(in srgb, currentColor 34%, transparent),
        0 6px 18px rgba(67, 49, 32, 0.12);
    }

    .prism-letter[data-active="true"]::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 56%;
      width: 0.92em;
      height: 0.92em;
      border-radius: 999px;
      transform: translate(-50%, -50%);
      background: radial-gradient(circle, color-mix(in srgb, currentColor 34%, transparent), transparent 68%);
      filter: blur(8px);
      opacity: 0.82;
      z-index: -1;
      pointer-events: none;
    }

    body.night-mode .prism-letter[data-active="true"] {
      filter: saturate(1.22) brightness(1.12);
      text-shadow:
        0 0 18px color-mix(in srgb, currentColor 74%, transparent),
        0 0 40px color-mix(in srgb, currentColor 42%, transparent),
        0 6px 18px rgba(0, 0, 0, 0.30);
    }

    .prism-subtitle {
      margin: 4px 0 14px;
      font-size: clamp(18px, 2.5vw, 28px);
      font-weight: 700;
      color: var(--text);
      opacity: 0.88;
      letter-spacing: 0.02em;
    }

    .hero p {
      margin: 0;
      color: var(--muted);
      line-height: 1.8;
      max-width: 720px;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .primary, .secondary, .ghost, .danger {
      min-height: 42px;
      padding: 10px 14px;
      border-radius: 14px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
      user-select: none;
    }

    .primary {
      color: white;
      background: var(--accent);
      box-shadow: 0 10px 22px rgba(119, 85, 178, 0.24);
    }

    .secondary {
      color: var(--text);
      background: var(--accent-soft);
      border: 1px solid rgba(119, 85, 178, 0.18);
    }

    .ghost {
      color: var(--text);
      background: transparent;
      border: 1px solid var(--line);
    }

    .danger {
      color: var(--danger);
      background: rgba(155, 55, 48, 0.08);
      border: 1px solid rgba(155, 55, 48, 0.18);
    }

    .primary:hover, .secondary:hover, .ghost:hover, .danger:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 22px rgba(67, 49, 32, 0.10);
    }

    .side-card {
      padding: 18px;
      display: grid;
      gap: 12px;
    }

    .stat-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }

    .recent-card {
      border: 1px solid var(--line);
      background: var(--card);
      border-radius: 18px;
      padding: 14px;
    }

    .recent-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      margin-bottom: 10px;
    }

    .recent-title {
      font-weight: 700;
    }

    .recent-list {
      display: grid;
      gap: 8px;
    }

    .recent-item {
      width: 100%;
      text-align: left;
      color: var(--text);
      background: rgba(119, 85, 178, 0.07);
      border: 1px solid rgba(119, 85, 178, 0.13);
      border-radius: 14px;
      padding: 9px 10px;
      display: grid;
      gap: 4px;
    }

    .recent-item:hover {
      transform: translateY(-1px);
    }

    .recent-item[disabled] {
      cursor: default;
      opacity: .62;
    }

    .recent-name {
      font-weight: 600;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .recent-meta {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }

    .stat {
      border: 1px solid var(--line);
      background: var(--card);
      border-radius: 18px;
      padding: 14px;
    }

    .stat .label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 6px;
    }

    .stat .value {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: -0.04em;
    }

    .toolbar {
      display: grid;
      grid-template-columns: 1fr auto auto auto;
      gap: 10px;
      margin: 18px 0;
      align-items: center;
    }

    .view-switch {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px;
      border-radius: 16px;
      background: rgba(255, 253, 248, 0.82);
      border: 1px solid var(--line);
      box-shadow: 0 8px 20px rgba(67, 49, 32, 0.06);
    }

    .view-btn {
      min-height: 34px;
      padding: 8px 12px;
      border-radius: 12px;
      background: transparent;
      color: var(--muted);
      white-space: nowrap;
      transition: background .2s ease, color .2s ease, transform .2s ease;
    }

    .view-btn:hover {
      color: var(--text);
      transform: translateY(-1px);
    }

    .view-btn.active {
      background: var(--accent-soft);
      color: var(--text);
      border: 1px solid rgba(119, 85, 178, 0.18);
    }

    .input, .select {
      width: 100%;
      min-height: 42px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: rgba(255, 253, 248, 0.88);
      color: var(--text);
      padding: 10px 12px;
      outline: none;
    }

    .input:focus, .select:focus {
      border-color: rgba(119, 85, 178, 0.55);
      box-shadow: 0 0 0 4px var(--accent-soft);
    }

    .category-bar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .chip {
      background: rgba(255, 253, 248, 0.85);
      color: var(--text);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 8px 12px;
    }

    .chip.active {
      color: white;
      background: var(--accent);
      border-color: transparent;
    }

    .main-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 360px;
      gap: 18px;
      align-items: start;
    }

    .shelf-wrapper {
      display: grid;
      gap: 16px;
    }

    .shelf-wrapper.columns-view {
      display: flex;
      gap: 16px;
      overflow-x: auto;
      align-items: flex-start;
      padding-bottom: 6px;
    }

    .shelf-section {
      background: linear-gradient(180deg, rgba(255,253,248,0.82), rgba(250,239,223,0.72));
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 16px 16px 22px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .shelf-section.column-mode {
      position: relative;
      flex: 0 0 var(--section-width, 240px);
      width: var(--section-width, 240px);
    }

    .width-control {
      display: flex;
      justify-content: flex-end;
      align-items: center;
      margin: -4px 0 12px;
    }

    .fit-width-btn {
      width: 46px;
      height: 42px;
      border-radius: 16px;
      color: var(--section-accent, var(--accent));
      background:
        radial-gradient(circle at 30% 78%, color-mix(in srgb, var(--section-accent, var(--accent)) 16%, transparent), transparent 28%),
        rgba(255,253,248,0.72);
      border: 1px solid rgba(55, 37, 22, 0.12);
      display: grid;
      place-items: center;
      box-shadow: 0 8px 18px rgba(67,49,32,0.08);
      transition: transform .22s cubic-bezier(.2,.9,.2,1.2), box-shadow .22s ease, background .22s ease;
    }

    .fit-width-btn:hover {
      transform: translateY(-2px) rotate(-2deg);
      box-shadow: 0 12px 24px rgba(67,49,32,0.12);
      background: color-mix(in srgb, var(--section-accent, var(--accent)) 12%, rgba(255,253,248,0.78));
    }

    .fit-width-btn .fit-icon-mark {
      --fit-icon-mask: url("data:image/png;base64,");
      width: 34px;
      height: 34px;
      display: block;
      background: currentColor;
      -webkit-mask: var(--fit-icon-mask) center / contain no-repeat;
      mask: var(--fit-icon-mask) center / contain no-repeat;
      opacity: .94;
      transform: translateY(1px);
      filter:
        drop-shadow(0 1px 0 rgba(255,255,255,0.46))
        drop-shadow(0 3px 5px rgba(67,49,32,0.12));
    }

    .shelf-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .shelf-head h2 {
      margin: 0;
      font-size: 18px;
    }

    .shelf-count {
      color: var(--muted);
      font-size: 13px;
    }

    .shelf-line {
      position: relative;
      display: flex;
      align-items: flex-end;
      gap: 9px;
      min-height: 226px;
      padding: 8px 8px 19px;
      overflow-x: auto;
      scrollbar-width: thin;
    }

    .shelf-section.column-mode .shelf-line {
      min-height: 0;
      max-height: 68vh;
      padding: 4px 8px 4px 0;
      overflow-y: auto;
      overflow-x: hidden;
      align-items: stretch;
      flex-direction: column;
      gap: 8px;
    }

    .shelf-line::after {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      bottom: 0;
      height: 18px;
      border-radius: 0 0 18px 18px;
      background: linear-gradient(180deg, var(--wood), var(--wood-dark));
      box-shadow: inset 0 3px 0 rgba(255,255,255,0.18), 0 6px 16px rgba(77, 48, 26, 0.22);
    }

    .shelf-section.column-mode .shelf-line::after {
      left: auto;
      right: 0;
      top: 0;
      bottom: 0;
      width: 14px;
      height: auto;
      border-radius: 0 14px 14px 0;
      background: linear-gradient(90deg, var(--wood), var(--wood-dark));
      box-shadow: inset 2px 0 0 rgba(255,255,255,0.16), 0 6px 16px rgba(77, 48, 26, 0.18);
    }

    .book-spine {
      --h: 160px;
      --w: 44px;
      position: relative;
      z-index: 1;
      width: var(--w);
      min-width: var(--w);
      height: var(--h);
      padding: 12px 5px 10px;
      border-radius: 8px 8px 4px 4px;
      border: 1px solid rgba(55, 37, 22, 0.22);
      color: #fff;
      background:
        linear-gradient(90deg, rgba(255,255,255,0.16), transparent 24%, rgba(0,0,0,0.12) 100%),
        var(--book-color, #7d6bb2);
      box-shadow: 5px 8px 14px rgba(44, 30, 19, 0.18);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: space-between;
      transition: transform .25s ease, box-shadow .25s ease, filter .25s ease;
    }

    .book-spine:hover, .book-spine.active {
      transform: translateY(-12px) rotate(-1.6deg);
      box-shadow: 7px 18px 24px rgba(44, 30, 19, 0.24);
      filter: saturate(1.08);
    }

    .shelf-section.column-mode .book-spine {
      width: calc(100% - 16px);
      min-width: calc(100% - 16px);
      height: var(--h);
      padding: 10px 10px 10px 12px;
      border-radius: 12px;
      flex-direction: row;
      align-items: center;
      justify-content: flex-start;
      gap: 10px;
    }

    .shelf-section.column-mode .book-spine:hover,
    .shelf-section.column-mode .book-spine.active {
      transform: translateX(-4px);
    }

    .spine-title {
      writing-mode: vertical-rl;
      text-orientation: upright;
      text-transform: none;
      overflow: hidden;
      height: calc(var(--h) - 44px);
      width: calc(var(--w) - 10px);
      font-size: var(--spine-font-size, 14px);
      line-height: 1.03;
      letter-spacing: 0.02em;
      word-break: break-all;
      overflow-wrap: anywhere;
      text-shadow: 0 1px 2px rgba(0,0,0,0.22);
    }

    .shelf-section.column-mode .spine-title {
      writing-mode: horizontal-tb;
      text-orientation: mixed;
      height: auto;
      width: auto;
      max-width: none;
      flex: 1 1 auto;
      line-height: 1.28;
      letter-spacing: 0.01em;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      word-break: break-word;
    }

    .spine-title.too-long {
      -webkit-mask-image: linear-gradient(to bottom, #000 calc(100% - 22px), transparent);
      mask-image: linear-gradient(to bottom, #000 calc(100% - 22px), transparent);
    }

    .spine-ext {
      font-size: 11px;
      opacity: 0.86;
      background: rgba(0,0,0,0.18);
      border-radius: 999px;
      padding: 2px 5px;
    }

    .shelf-section.column-mode .spine-ext {
      font-size: 10px;
      margin-left: auto;
      flex: 0 0 auto;
    }

    .book-detail {
      position: sticky;
      top: 18px;
      background: rgba(255, 253, 248, 0.90);
      border: 1px solid var(--line);
      border-radius: 24px;
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .cover-stage {
      height: 240px;
      border: 1px dashed var(--line);
      border-radius: 20px;
      display: grid;
      place-items: center;
      margin-bottom: 14px;
      background:
        linear-gradient(135deg, rgba(119,85,178,0.08), rgba(169,121,79,0.10)),
        var(--card);
      perspective: 800px;
      overflow: hidden;
    }

    .book-cover {
      width: 142px;
      height: 198px;
      border-radius: 13px;
      border: 1px solid rgba(55, 37, 22, 0.22);
      background:
        linear-gradient(110deg, rgba(255,255,255,0.25), transparent 35%),
        var(--cover-color, #7d6bb2);
      color: white;
      box-shadow: 13px 18px 26px rgba(44, 30, 19, 0.24);
      padding: 18px 14px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      transform-origin: left center;
      animation: turnFront .56s cubic-bezier(.2,.75,.2,1) both;
    }

    .cover-title {
      font-weight: 700;
      line-height: 1.35;
      word-break: break-word;
    }

    .cover-ext {
      opacity: 0.88;
      font-size: 12px;
    }

    @keyframes turnFront {
      0% { transform: rotateY(78deg) translateX(-22px); opacity: .42; }
      55% { transform: rotateY(-6deg) translateX(0); opacity: 1; }
      100% { transform: rotateY(0deg) translateX(0); opacity: 1; }
    }

    .detail-title {
      margin: 0 0 8px;
      font-size: 20px;
      line-height: 1.25;
    }

    .meta-list {
      display: grid;
      gap: 8px;
      margin: 12px 0 16px;
    }

    .meta-item {
      display: grid;
      grid-template-columns: 72px 1fr;
      gap: 8px;
      color: var(--muted);
      font-size: 14px;
    }

    .meta-item b {
      color: var(--text);
      font-weight: 600;
    }

    .empty-panel {
      padding: 28px;
      text-align: center;
      color: var(--muted);
    }

    .reader-overlay {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: none;
      background: rgba(35, 27, 21, 0.46);
      padding: 22px;
    }

    .reader-overlay.open {
      display: grid;
    }

    .reader-overlay.fullscreen {
      padding: 0;
      background: rgba(35, 27, 21, 0.72);
    }

    .reader-panel {
      width: min(1180px, 100%);
      height: min(860px, calc(100vh - 44px));
      margin: auto;
      padding: 16px;
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 12px;
    }

    .reader-overlay.fullscreen .reader-panel {
      width: 100%;
      height: 100vh;
      border-radius: 0;
      border: 0;
    }

    .reader-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .reader-preferences {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      justify-content: flex-end;
    }

    .reader-preferences .select {
      width: auto;
      min-width: 118px;
    }

    .reader-preferences .ghost,
    .reader-preferences .secondary {
      min-height: 36px;
      padding: 7px 10px;
      border-radius: 12px;
    }

    .reader-title {
      margin: 0;
      font-size: 18px;
      min-width: 0;
      overflow: hidden;
      white-space: nowrap;
      text-overflow: ellipsis;
    }

    .reader-body {
      --read-bg: #fffdf8;
      --read-text: #1f1a16;
      --read-font-size: 18px;
      min-height: 0;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--read-bg);
      color: var(--read-text);
      overflow: hidden;
      display: grid;
    }

    .reader-overlay.fullscreen .reader-body {
      border-radius: 0;
    }

    .reader-body iframe, .reader-body object {
      width: 100%;
      height: 100%;
      border: 0;
    }

    .text-reader {
      overflow: auto;
      padding: 28px;
      line-height: 1.9;
      white-space: pre-wrap;
      font-family: ui-serif, Georgia, "Songti SC", "SimSun", serif;
      color: var(--read-text);
      background: var(--read-bg);
      font-size: var(--read-font-size);
    }


    .reader-loading {
      padding: 24px;
      color: var(--muted);
      line-height: 1.8;
    }

    .reader-tools {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      padding: 10px;
      border-bottom: 1px solid var(--line);
      background: var(--read-bg);
    }

    .reader-tools .select {
      flex: 1 1 220px;
      min-width: 0;
    }

    .reader-status {
      color: var(--muted);
      font-size: 13px;
      margin-left: auto;
    }

    .epub-shell {
      min-height: 0;
      height: 100%;
      display: grid;
      grid-template-rows: auto 1fr;
      background: var(--read-bg);
    }

    .epub-viewer {
      min-height: 0;
      height: 100%;
      overflow: hidden;
      padding: 8px 0;
    }

    .epub-viewer iframe {
      background: var(--read-bg);
    }

    .docx-reader {
      overflow: auto;
      padding: 34px min(56px, 6vw);
      line-height: 1.9;
      color: var(--read-text);
      background: var(--read-bg);
      font-family: ui-serif, Georgia, "Songti SC", "SimSun", serif;
      font-size: var(--read-font-size);
    }

    .docx-reader h1, .docx-reader h2, .docx-reader h3 {
      line-height: 1.35;
      margin: 1.2em 0 .55em;
    }

    .docx-reader p {
      margin: .75em 0;
    }

    .docx-reader img {
      max-width: 100%;
      height: auto;
      border-radius: 10px;
    }

    .docx-warnings {
      padding: 10px 16px;
      border-bottom: 1px solid var(--line);
      background: rgba(119, 85, 178, 0.08);
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    .reader-choice {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .mobi-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 14px;
    }

    .notice {
      padding: 22px;
      color: var(--muted);
      line-height: 1.8;
    }

    .hidden {
      display: none;
    }

    @media (max-width: 900px) {
      .hero, .main-grid, .toolbar {
        grid-template-columns: 1fr;
      }

      .view-switch {
        overflow-x: auto;
      }

      .book-detail {
        position: static;
      }
    }

    @media (max-width: 520px) {
      .app {
        width: min(100vw - 18px, 1180px);
        padding-top: 12px;
      }

      .hero-card, .side-card, .book-detail, .shelf-section {
        border-radius: 18px;
      }

      .stat-grid {
        grid-template-columns: 1fr;
      }

      .reader-overlay {
        padding: 8px;
      }

      .reader-panel {
        height: calc(100vh - 16px);
      }

      .reader-preferences {
        width: 100%;
        justify-content: flex-start;
      }

      .reader-choice {
        grid-template-columns: 1fr;
      }

      .view-switch {
        width: 100%;
      }
    }
  

    /* ===== Day / Night Theme Toggle ===== */
    .theme-toggle {
      min-width: 112px;
      position: relative;
      overflow: hidden;
      border-color: rgba(119, 85, 178, 0.20);
      background:
        radial-gradient(circle at 22% 50%, rgba(255,255,255,0.74), transparent 22%),
        rgba(255,253,248,0.78);
    }

    .theme-toggle .theme-icon {
      width: 22px;
      height: 22px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      font-size: 16px;
      line-height: 1;
      background: var(--accent-soft);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.38);
    }

    body.night-mode {
      --bg: #15110e;
      --panel: #211a15;
      --card: #2a211a;
      --wood: #7e5738;
      --wood-dark: #3f281a;
      --line: rgba(244, 226, 201, 0.16);
      --text: #f2e9dc;
      --muted: #b8aa9a;
      --accent-soft: rgba(145, 99, 216, 0.22);
      --danger: #ef8a7f;
      --shadow: 0 18px 46px rgba(0, 0, 0, 0.34);
      background:
        radial-gradient(circle at 12% 10%, rgba(145, 99, 216, 0.18), transparent 28%),
        radial-gradient(circle at 84% 12%, rgba(232, 161, 68, 0.13), transparent 30%),
        linear-gradient(180deg, #18130f 0%, #120f0d 54%, #0d0b0a 100%);
      color: var(--text);
    }

    body.night-mode .wave-canvas {
      opacity: 0.78;
      filter: saturate(1.22) brightness(1.08);
    }

    body.night-mode::after {
      background:
        radial-gradient(circle at 50% 0%, rgba(255,255,255,0.055), transparent 45%),
        linear-gradient(180deg, rgba(20,16,13,0.18), rgba(12,10,9,0.52));
    }

    body.night-mode .hero-card,
    body.night-mode .side-card,
    body.night-mode .reader-panel,
    body.night-mode .empty-panel,
    body.night-mode .book-detail {
      background: rgba(34, 27, 22, 0.84);
      border-color: var(--line);
      box-shadow: var(--shadow);
    }

    body.night-mode .shelf-section {
      background: linear-gradient(180deg, rgba(38,31,25,0.88), rgba(29,23,18,0.82));
      border-color: var(--line);
      box-shadow: var(--shadow);
    }

    body.night-mode .stat,
    body.night-mode .recent-card,
    body.night-mode .cover-stage {
      background: rgba(42, 33, 26, 0.86);
      border-color: var(--line);
    }

    body.night-mode .recent-item {
      color: var(--text);
      background: rgba(145, 99, 216, 0.14);
      border-color: rgba(175, 145, 230, 0.22);
    }

    body.night-mode .input,
    body.night-mode .select {
      background: rgba(35, 28, 22, 0.92);
      color: var(--text);
      border-color: var(--line);
    }

    body.night-mode .input::placeholder {
      color: rgba(232, 221, 208, 0.46);
    }

    body.night-mode .view-switch,
    body.night-mode .chip,
    body.night-mode .ghost,
    body.night-mode .theme-toggle {
      color: var(--text);
      background: rgba(35, 28, 22, 0.74);
      border-color: var(--line);
    }

    body.night-mode .secondary,
    body.night-mode .view-btn.active {
      color: var(--text);
      background: color-mix(in srgb, var(--accent) 20%, rgba(35,28,22,0.82));
      border-color: color-mix(in srgb, var(--accent) 42%, rgba(244,226,201,0.10));
    }

    body.night-mode .primary {
      box-shadow: 0 12px 28px color-mix(in srgb, var(--accent) 34%, transparent);
    }

    body.night-mode .danger {
      color: #f3aaa2;
      background: rgba(239, 138, 127, 0.10);
      border-color: rgba(239, 138, 127, 0.22);
    }

    body.night-mode .spectrum-pill {
      background: rgba(35,28,22,0.66);
      border-color: rgba(244,226,201,0.10);
    }

    body.night-mode .eyebrow {
      color: #dfd2ff;
      background: rgba(145,99,216,0.18);
    }

    body.night-mode .shelf-line::after {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.11), transparent),
        linear-gradient(180deg, #8a5c3a, #3c2417);
      box-shadow: inset 0 3px 0 rgba(255,255,255,0.10), 0 8px 22px rgba(0,0,0,0.34);
    }

    body.night-mode .shelf-section.column-mode .shelf-line::after {
      background:
        linear-gradient(90deg, rgba(255,255,255,0.10), transparent),
        linear-gradient(90deg, #8a5c3a, #3c2417);
    }

    body.night-mode .book-spine {
      box-shadow: 7px 12px 22px rgba(0,0,0,0.30), inset 1px 0 0 rgba(255,255,255,0.24), inset -2px 0 0 rgba(0,0,0,0.18);
    }

    body.night-mode .book-spine:hover,
    body.night-mode .book-spine.active {
      box-shadow: 9px 20px 30px rgba(0,0,0,0.38), 0 0 0 1px rgba(255,255,255,0.05), inset 1px 0 0 rgba(255,255,255,0.25), inset -2px 0 0 rgba(0,0,0,0.20);
    }

    body.night-mode .book-cover {
      box-shadow: 14px 20px 30px rgba(0,0,0,0.42);
    }

    body.night-mode .fit-width-btn {
      background:
        radial-gradient(circle at 30% 78%, color-mix(in srgb, var(--section-accent, var(--accent)) 24%, transparent), transparent 28%),
        rgba(35,28,22,0.78);
      border-color: rgba(244,226,201,0.14);
      box-shadow: 0 10px 22px rgba(0,0,0,0.22);
    }

    body.night-mode .reader-overlay {
      background: rgba(10, 8, 7, 0.62);
    }

    body.night-mode .reader-body {
      border-color: var(--line);
    }

    body.night-mode .theme-toggle {
      background:
        radial-gradient(circle at 76% 38%, rgba(255,246,207,0.42), transparent 11%),
        radial-gradient(circle at 24% 64%, color-mix(in srgb, var(--accent) 20%, transparent), transparent 28%),
        rgba(35,28,22,0.78);
    }

    body.night-mode .theme-toggle .theme-icon {
      background: rgba(255,246,207,0.12);
      box-shadow: 0 0 16px color-mix(in srgb, var(--accent) 45%, transparent), inset 0 1px 0 rgba(255,255,255,0.20);
    }



    /* ===== Clean home / help / collapsible recent ===== */
    .app {
      position: relative;
    }

    .help-fab {
      position: absolute;
      top: 10px;
      right: 0;
      width: 42px;
      height: 42px;
      border-radius: 999px;
      background: rgba(255,253,248,0.88);
      border: 1px solid var(--line);
      color: var(--text);
      box-shadow: 0 10px 24px rgba(67,49,32,0.10);
      display: grid;
      place-items: center;
      font-size: 22px;
      font-weight: 700;
      z-index: 6;
      transition: transform .18s ease, box-shadow .18s ease, background .18s ease;
    }

    .help-fab:hover {
      transform: translateY(-1px);
      box-shadow: 0 14px 28px rgba(67,49,32,0.14);
      background: color-mix(in srgb, white 78%, var(--accent) 22%);
    }

    .hero-card.clean-hero {
      display: grid;
      align-content: center;
      gap: 12px;
    }

    .hero-card.clean-hero .actions {
      margin-top: 4px;
    }

    .recent-card.collapsed {
      padding-bottom: 12px;
    }

    .recent-head {
      cursor: pointer;
      border-radius: 14px;
      padding: 4px 6px;
      margin: -4px -6px 0;
      transition: background .18s ease;
    }

    .recent-head:hover {
      background: rgba(119, 85, 178, 0.07);
    }

    .recent-title-wrap {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .recent-toggle-icon {
      width: 24px;
      height: 24px;
      border-radius: 999px;
      display: inline-grid;
      place-items: center;
      color: var(--muted);
      background: rgba(119, 85, 178, 0.08);
      transition: transform .22s ease, color .22s ease, background .22s ease;
    }

    .recent-card.open .recent-toggle-icon {
      transform: rotate(90deg);
      color: var(--accent);
      background: var(--accent-soft);
    }

    .recent-list {
      max-height: 360px;
      overflow: hidden;
      transition: max-height .32s cubic-bezier(.2,.8,.2,1), opacity .22s ease, margin-top .22s ease;
    }

    .recent-card.collapsed .recent-list {
      max-height: 0;
      opacity: 0;
      margin-top: 0;
      pointer-events: none;
    }

    .recent-card.open .recent-list {
      opacity: 1;
      margin-top: 10px;
    }

    .help-overlay {
      position: fixed;
      inset: 0;
      z-index: 60;
      display: none;
      background: rgba(35, 27, 21, 0.46);
      padding: 24px;
    }

    .help-overlay.open {
      display: grid;
    }

    .help-panel {
      width: min(880px, 100%);
      max-height: min(88vh, 920px);
      overflow: auto;
      margin: auto;
      border-radius: 26px;
      background: rgba(255,253,248,0.96);
      border: 1px solid var(--line);
      box-shadow: 0 18px 42px rgba(67,49,32,0.18);
      padding: 22px 22px 18px;
      backdrop-filter: blur(12px);
    }

    .help-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 14px;
    }

    .help-title {
      margin: 0;
      font-size: 24px;
      letter-spacing: -0.03em;
    }

    .help-subtitle {
      color: var(--muted);
      line-height: 1.8;
      margin: 8px 0 0;
      font-size: 14px;
    }

    .help-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
      margin-top: 14px;
    }

    .help-card {
      border-radius: 18px;
      border: 1px solid var(--line);
      background: var(--card);
      padding: 16px;
    }

    .help-card h3 {
      margin: 0 0 10px;
      font-size: 16px;
    }

    .help-card p,
    .help-card li {
      color: var(--muted);
      line-height: 1.75;
      font-size: 14px;
    }

    .help-card ul {
      margin: 0;
      padding-left: 18px;
    }

    .help-color-list {
      display: grid;
      gap: 8px;
      margin-top: 8px;
    }

    .help-color-item {
      display: flex;
      gap: 8px;
      align-items: center;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }

    .help-color-dot {
      width: 9px;
      height: 9px;
      border-radius: 999px;
      flex: 0 0 auto;
      background: currentColor;
      box-shadow: 0 0 0 5px color-mix(in srgb, currentColor 14%, transparent);
    }

    body.night-mode .help-fab {
      background: rgba(35, 28, 22, 0.82);
      border-color: var(--line);
      color: var(--text);
      box-shadow: 0 12px 26px rgba(0,0,0,0.28);
    }

    body.night-mode .help-fab:hover {
      background: color-mix(in srgb, var(--accent) 18%, rgba(35,28,22,0.86));
    }

    body.night-mode .help-overlay {
      background: rgba(8, 7, 6, 0.64);
    }

    body.night-mode .help-panel {
      background: rgba(34, 27, 22, 0.96);
      border-color: var(--line);
      box-shadow: 0 20px 48px rgba(0,0,0,0.42);
    }

    body.night-mode .help-card {
      background: rgba(42, 33, 26, 0.88);
      border-color: var(--line);
    }

    body.night-mode .recent-head:hover {
      background: rgba(145, 99, 216, 0.13);
    }

    body.night-mode .recent-toggle-icon {
      background: rgba(145, 99, 216, 0.16);
      color: rgba(232,221,208,0.72);
    }

    body.night-mode .recent-card.open .recent-toggle-icon {
      color: #dfd2ff;
      background: rgba(145,99,216,0.24);
      box-shadow: 0 0 14px rgba(145,99,216,0.22);
    }

    @media (max-width: 900px) {
      .help-grid {
        grid-template-columns: 1fr;
      }
      .help-fab {
        top: 6px;
        right: 0;
      }
    }

  

    /* ===== Theme-matched scrollbars + upper shelf rail ===== */
    html {
      scrollbar-width: thin;
      scrollbar-color: color-mix(in srgb, var(--accent) 46%, var(--wood) 54%) rgba(169, 121, 79, 0.14);
    }

    *::-webkit-scrollbar {
      width: 12px;
      height: 12px;
    }

    *::-webkit-scrollbar-track {
      background: rgba(169, 121, 79, 0.13);
      border-radius: 999px;
    }

    *::-webkit-scrollbar-thumb {
      border-radius: 999px;
      border: 3px solid rgba(255, 253, 248, 0.70);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.20), rgba(255,255,255,0.02)),
        linear-gradient(180deg, color-mix(in srgb, var(--accent) 38%, var(--wood) 62%), color-mix(in srgb, var(--wood-dark) 72%, var(--accent) 28%));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.22);
    }

    *::-webkit-scrollbar-thumb:hover {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.04)),
        linear-gradient(180deg, color-mix(in srgb, var(--accent) 54%, var(--wood) 46%), color-mix(in srgb, var(--wood-dark) 58%, var(--accent) 42%));
    }

    .main-grid {
      min-width: 0;
    }

    .shelf-area {
      min-width: 0;
      display: grid;
      gap: 10px;
      align-items: start;
    }

    .shelf-wrapper {
      min-width: 0;
    }

    .shelf-wrapper.columns-view {
      padding-bottom: 0;
      scrollbar-width: none;
    }

    .shelf-wrapper.columns-view::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    .shelf-top-scrollbar {
      display: none;
      height: 22px;
      overflow-x: auto;
      overflow-y: hidden;
      padding: 5px 6px;
      border-radius: 999px;
      border: 1px solid rgba(86, 63, 42, 0.14);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.34), rgba(255,255,255,0.08)),
        rgba(255, 253, 248, 0.66);
      box-shadow: 0 8px 18px rgba(67,49,32,0.08), inset 0 1px 0 rgba(255,255,255,0.40);
      scrollbar-width: thin;
      scrollbar-color: color-mix(in srgb, var(--accent) 48%, var(--wood) 52%) rgba(169, 121, 79, 0.16);
    }

    .shelf-top-scrollbar.visible {
      display: block;
    }

    .shelf-top-scrollbar::-webkit-scrollbar {
      height: 12px;
    }

    .shelf-top-scrollbar::-webkit-scrollbar-track {
      border-radius: 999px;
      background: rgba(169, 121, 79, 0.15);
    }

    .shelf-top-scrollbar::-webkit-scrollbar-thumb {
      border-radius: 999px;
      border: 3px solid rgba(255,253,248,0.76);
      background:
        linear-gradient(90deg, rgba(255,255,255,0.22), rgba(255,255,255,0.04)),
        linear-gradient(90deg, color-mix(in srgb, var(--accent) 48%, var(--wood) 52%), color-mix(in srgb, var(--wood-dark) 58%, var(--accent) 42%));
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.24), 0 2px 5px rgba(67,49,32,0.12);
    }

    .shelf-top-scrollbar-inner {
      height: 1px;
      min-width: 1px;
    }

    body.night-mode {
      scrollbar-color: color-mix(in srgb, var(--accent) 60%, #b88955 40%) rgba(244, 226, 201, 0.10);
    }

    body.night-mode *::-webkit-scrollbar-track {
      background: rgba(244, 226, 201, 0.08);
    }

    body.night-mode *::-webkit-scrollbar-thumb {
      border-color: rgba(24, 19, 15, 0.78);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.16), rgba(255,255,255,0.02)),
        linear-gradient(180deg, color-mix(in srgb, var(--accent) 54%, #b88955 46%), #5a3a25);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.16), 0 0 14px color-mix(in srgb, var(--accent) 20%, transparent);
    }

    body.night-mode *::-webkit-scrollbar-thumb:hover {
      background:
        linear-gradient(180deg, rgba(255,255,255,0.22), rgba(255,255,255,0.03)),
        linear-gradient(180deg, color-mix(in srgb, var(--accent) 68%, #c5945a 32%), #6c452b);
    }

    body.night-mode .shelf-top-scrollbar {
      border-color: rgba(244, 226, 201, 0.12);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.018)),
        rgba(30, 24, 20, 0.76);
      box-shadow: 0 10px 24px rgba(0,0,0,0.24), inset 0 1px 0 rgba(255,255,255,0.08);
      scrollbar-color: color-mix(in srgb, var(--accent) 66%, #b88955 34%) rgba(244, 226, 201, 0.10);
    }

    body.night-mode .shelf-top-scrollbar::-webkit-scrollbar-track {
      background: rgba(244, 226, 201, 0.09);
    }

    body.night-mode .shelf-top-scrollbar::-webkit-scrollbar-thumb {
      border-color: rgba(30, 24, 20, 0.88);
      background:
        linear-gradient(90deg, rgba(255,255,255,0.16), rgba(255,255,255,0.02)),
        linear-gradient(90deg, color-mix(in srgb, var(--accent) 62%, #c6945a 38%), #6c452b);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.14), 0 0 14px color-mix(in srgb, var(--accent) 18%, transparent);
    }

    @media (max-width: 900px) {
      .shelf-area {
        min-width: 0;
      }
    }

  </style>
</head>
<body>
  <canvas id="waveCanvas" class="wave-canvas" aria-hidden="true"></canvas>
  <main class="app">
    <button id="helpButton" class="help-fab" type="button" aria-label="帮助与说明" title="帮助与说明">?</button>
    <section class="hero">
      <div class="hero-card clean-hero">
        <h1 id="prismTitle" class="prism-title active-0" aria-label="prism">
          <span class="prism-letter" data-index="0" data-color="red" data-letter="p" role="button" tabindex="0" aria-label="切换到红色主题" onclick="window.prismLetterClick && window.prismLetterClick(0)" onmouseenter="window.prismLetterHover && window.prismLetterHover(0)" onkeydown="window.prismLetterKey && window.prismLetterKey(event, 0)">p</span>
          <span class="prism-letter" data-index="1" data-color="orange" data-letter="r" role="button" tabindex="0" aria-label="切换到橙色主题" onclick="window.prismLetterClick && window.prismLetterClick(1)" onmouseenter="window.prismLetterHover && window.prismLetterHover(1)" onkeydown="window.prismLetterKey && window.prismLetterKey(event, 1)">r</span>
          <span class="prism-letter" data-index="2" data-color="green" data-letter="i" role="button" tabindex="0" aria-label="切换到绿色主题" onclick="window.prismLetterClick && window.prismLetterClick(2)" onmouseenter="window.prismLetterHover && window.prismLetterHover(2)" onkeydown="window.prismLetterKey && window.prismLetterKey(event, 2)">i</span>
          <span class="prism-letter" data-index="3" data-color="blue" data-letter="s" role="button" tabindex="0" aria-label="切换到蓝色主题" onclick="window.prismLetterClick && window.prismLetterClick(3)" onmouseenter="window.prismLetterHover && window.prismLetterHover(3)" onkeydown="window.prismLetterKey && window.prismLetterKey(event, 3)">s</span>
          <span class="prism-letter" data-index="4" data-color="purple" data-letter="m" role="button" tabindex="0" aria-label="切换到紫色主题" onclick="window.prismLetterClick && window.prismLetterClick(4)" onmouseenter="window.prismLetterHover && window.prismLetterHover(4)" onkeydown="window.prismLetterKey && window.prismLetterKey(event, 4)">m</span>
        </h1>
        <div class="actions">
