      <aside class="side-card" aria-live="polite">
        <div class="stat-grid">
          <div class="stat"><div class="label">书籍数量</div><div id="bookCount" class="value">0</div></div>
          <div class="stat"><div class="label">分类数量</div><div id="categoryCount" class="value">0</div></div>
          <div class="stat"><div class="label">总大小</div><div id="totalSize" class="value">0 MB</div></div>
          <div class="stat"><div class="label">当前模式</div><div id="modeText" class="value">待导入</div></div>
        </div>
        <div id="recentCard" class="recent-card collapsed">
          <div id="recentToggle" class="recent-head" role="button" tabindex="0" aria-expanded="false" aria-controls="recentList">
            <div class="recent-title-wrap">
              <span class="recent-toggle-icon" aria-hidden="true">›</span>
              <div class="recent-title">最近阅读</div>
            </div>
            <span id="recentCount" class="recent-meta">0 本</span>
          </div>
          <div id="recentList" class="recent-list">
            <div class="recent-meta">导入并打开书籍后，这里会显示最近阅读记录。</div>
          </div>
        </div>
      </aside>
    </section>

    <section class="toolbar" aria-label="书架工具栏">
      <input id="searchInput" class="input" type="search" placeholder="搜索书名、格式、分类……" />
      <select id="sortSelect" class="select" aria-label="排序方式">
        <option value="name">按书名排序</option>
        <option value="size-desc">按大小从大到小</option>
        <option value="size-asc">按大小从小到大</option>
        <option value="ext">按格式排序</option>
      </select>
      <div class="view-switch" aria-label="视图切换">
        <button id="viewRows" class="view-btn" type="button">分类纵向 / 书籍横向</button>
        <button id="viewColumns" class="view-btn" type="button">分类横向 / 书籍纵向</button>
      </div>
      <button id="showAll" class="ghost" type="button">显示全部分类</button>
