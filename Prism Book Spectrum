  <section id="helpOverlay" class="help-overlay" aria-modal="true" role="dialog" aria-label="帮助与说明">
    <div class="help-panel">
      <div class="help-head">
        <div>
          <h2 class="help-title">Prism · 帮助与说明</h2>
          <p class="help-subtitle">主界面只保留操作入口，说明内容集中在这里。Prism 的核心是把本地资料从文件堆转化为可观察、可分类、可阅读的虚拟书架。</p>
        </div>
        <button id="closeHelp" class="ghost" type="button">关闭</button>
      </div>
      <div class="help-grid">
        <section class="help-card">
          <h3>如何使用</h3>
          <ul>
            <li>点击“选择文件夹”导入本地资料，网页会按文件夹生成分类书架。</li>
            <li>点击书脊可查看封面视角和文件信息，再进入直接查看或全屏阅读。</li>
            <li>最近阅读默认收纳，点击“最近阅读”标题后会向下展开。</li>
            <li>昼夜切换会同步调整背景、卡片、书架和 Prism 波浪的亮度。</li>
          </ul>
        </section>
        <section class="help-card">
          <h3>支持格式</h3>
          <p>目前支持识别 PDF、EPUB、DOCX、TXT、MD、MOBI、AZW3。其中 PDF、EPUB、DOCX、TXT、MD 可直接在网页内阅读；MOBI、AZW3 以资源管理为主。</p>
        </section>
        <section class="help-card">
          <h3>Prism 光谱分类</h3>
          <div class="help-color-list">
            <div class="help-color-item" style="color:#dd5b5b"><span class="help-color-dot"></span><span>红色：重要通知 / 安全考核</span></div>
            <div class="help-color-item" style="color:#e8a144"><span class="help-color-dot"></span><span>橙色：课程教学 / 表格任务</span></div>
            <div class="help-color-item" style="color:#67a96a"><span class="help-color-dot"></span><span>绿色：实验科研 / 技术方法</span></div>
            <div class="help-color-item" style="color:#5d86d6"><span class="help-color-dot"></span><span>蓝色：学校行政 / 班级资料</span></div>
            <div class="help-color-item" style="color:#9163d8"><span class="help-color-dot"></span><span>紫色：人文阅读 / 总结拓展</span></div>
          </div>
        </section>
        <section class="help-card">
          <h3>视图与阅读</h3>
          <ul>
            <li>“分类纵向 / 书籍横向”更接近真实书架。</li>
            <li>“分类横向 / 书籍纵向”更适合总览不同分类的资料分布。</li>
            <li>阅读器支持字号、背景色、全屏阅读和进度保存。</li>
          </ul>
        </section>
      </div>
    </div>
  </section>

  <section id="readerOverlay" class="reader-overlay" aria-modal="true" role="dialog" aria-label="整页阅读器">
    <div class="reader-panel">
      <header class="reader-head">
        <h2 id="readerTitle" class="reader-title">阅读器</h2>
        <div class="reader-preferences" aria-label="阅读设置">
          <button id="fontDown" class="ghost" type="button">A−</button>
          <button id="fontUp" class="ghost" type="button">A+</button>
          <select id="bgSelect" class="select" aria-label="阅读背景色">
            <option value="paper">纸张</option>
            <option value="white">纯白</option>
            <option value="green">护眼</option>
            <option value="dark">夜间</option>
          </select>
          <button id="toggleFullscreen" class="secondary" type="button">全屏</button>
          <button id="closeReader" class="ghost" type="button">关闭</button>
        </div>
      </header>
      <div id="readerBody" class="reader-body"></div>
    </div>
  </section>

  <script src="https://cdn.jsdelivr.net/npm/epubjs@0.3.93/dist/epub.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/mammoth@1.8.0/mammoth.browser.min.js"></script>
  <script>
    const SUPPORTED_EXT = new Set(['pdf', 'epub', 'txt', 'md', 'mobi', 'azw3', 'docx']);
    const STORAGE_KEYS = {
      readerPrefs: 'webBookshelf.readerPrefs.v1',
      progress: 'webBookshelf.progress.v1',
      recents: 'webBookshelf.recents.v1',
      categoryWidths: 'webBookshelf.categoryWidths.v1',
      shelfView: 'webBookshelf.shelfView.v1',
      theme: 'webBookshelf.theme.v1'
    };
    const READ_THEMES = {
      paper: { bg: '#fffdf8', text: '#1f1a16', label: '纸张' },
      white: { bg: '#ffffff', text: '#191714', label: '纯白' },
      green: { bg: '#f1f7ed', text: '#182317', label: '护眼' },
      dark: { bg: '#1f1c19', text: '#eee7dc', label: '夜间' }
    };
    const state = {
      books: [],
      selectedCategory: '全部',
      selectedBookId: null,
      search: '',
      sort: 'name',
      objectUrl: null,
      objectUrls: [],
      epubBook: null,
      epubRendition: null,
      currentReaderBook: null,
      currentReaderKind: null,
      readerPrefs: loadJson(STORAGE_KEYS.readerPrefs, { fontSize: 18, bg: 'paper' }),
      progress: loadJson(STORAGE_KEYS.progress, {}),
      recents: loadJson(STORAGE_KEYS.recents, []),
      categoryWidths: loadJson(STORAGE_KEYS.categoryWidths, {}),
      shelfView: loadJson(STORAGE_KEYS.shelfView, 'rows'),
      theme: loadJson(STORAGE_KEYS.theme, 'day'),
      rootName: '未选择根目录',
      activeColorIndex: 0,
      prismClickFocus: null
    };

    const prismPalette = [
      { name: 'red', hex: '#dd5b5b', glow: 'rgba(221,91,91,0.42)' },
      { name: 'orange', hex: '#e8a144', glow: 'rgba(232,161,68,0.42)' },
      { name: 'green', hex: '#67a96a', glow: 'rgba(103,169,106,0.42)' },
      { name: 'blue', hex: '#5d86d6', glow: 'rgba(93,134,214,0.42)' },
      { name: 'purple', hex: '#9163d8', glow: 'rgba(145,99,216,0.42)' }
    ];

    function setVisualFocus(colorIndex = 0, color = prismPalette[colorIndex]?.hex || '#7755b2') {
      const safeIndex = Math.max(0, Math.min(prismPalette.length - 1, Number(colorIndex) || 0));
      const activeColor = color || prismPalette[safeIndex].hex;
      state.activeColorIndex = safeIndex;
      document.documentElement.style.setProperty('--accent', activeColor);
      document.documentElement.style.setProperty('--active-prism-color', activeColor);
      const prismTitle = document.getElementById('prismTitle');
      if (prismTitle) {
        prismTitle.className = `prism-title active-${safeIndex}`;
        prismTitle.querySelectorAll('.prism-letter').forEach(letter => {
          letter.dataset.active = String(Number(letter.dataset.index) === safeIndex);
        });
      }
      window.bookshelfSetWaveAccent?.(safeIndex);
    }

    function activatePrismLetter(index, shouldLock = true) {
      const safeIndex = Math.max(0, Math.min(prismPalette.length - 1, Number(index) || 0));
      if (shouldLock) state.prismClickFocus = safeIndex;
      setVisualFocus(safeIndex, prismPalette[safeIndex]?.hex || '#7755b2');
    }

    window.prismLetterClick = function prismLetterClick(index) {
      activatePrismLetter(index, true);
    };

    window.prismLetterHover = function prismLetterHover(index) {
      activatePrismLetter(index, false);
    };

    window.prismLetterKey = function prismLetterKey(event, index) {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        activatePrismLetter(index, true);
      }
    };

    function bindPrismLetterInteractions() {
      const prismTitle = document.getElementById('prismTitle');
      if (!prismTitle) return;
      prismTitle.addEventListener('click', event => {
        const letter = event.target.closest?.('.prism-letter');
        if (!letter || !prismTitle.contains(letter)) return;
        activatePrismLetter(Number(letter.dataset.index || 0), true);
      });
      prismTitle.addEventListener('pointermove', event => {
        const letter = event.target.closest?.('.prism-letter');
        if (!letter || !prismTitle.contains(letter)) return;
        activatePrismLetter(Number(letter.dataset.index || 0), false);
      });
      prismTitle.addEventListener('pointerleave', () => {
        if (state.prismClickFocus !== null) {
          activatePrismLetter(state.prismClickFocus, false);
          return;
        }
        const selected = state.books.find(candidate => candidate.id === state.selectedBookId);
        if (selected) setVisualFocus(selected.colorIndex, selected.color);
        else if (state.books[0]) setVisualFocus(state.books[0].colorIndex, state.books[0].color);
        else setVisualFocus(0, prismPalette[0].hex);
      });
      prismTitle.querySelectorAll('.prism-letter').forEach(letter => {
        letter.addEventListener('keydown', event => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            activatePrismLetter(Number(letter.dataset.index || 0), true);
          }
        });
      });
    }

    const el = {
      pickModern: document.getElementById('pickModern'),
      pickFallback: document.getElementById('pickFallback'),
      directoryInput: document.getElementById('directoryInput'),
      loadDemo: document.getElementById('loadDemo'),
      clearLibrary: document.getElementById('clearLibrary'),
      themeToggle: document.getElementById('themeToggle'),
      themeIcon: document.getElementById('themeIcon'),
      themeText: document.getElementById('themeText'),
      helpButton: document.getElementById('helpButton'),
      helpOverlay: document.getElementById('helpOverlay'),
      closeHelp: document.getElementById('closeHelp'),
      searchInput: document.getElementById('searchInput'),
      sortSelect: document.getElementById('sortSelect'),
      viewRows: document.getElementById('viewRows'),
      viewColumns: document.getElementById('viewColumns'),
      showAll: document.getElementById('showAll'),
      categoryBar: document.getElementById('categoryBar'),
      shelfTopScrollbar: document.getElementById('shelfTopScrollbar'),
      shelfTopScrollbarInner: document.getElementById('shelfTopScrollbarInner'),
      shelfWrapper: document.getElementById('shelfWrapper'),
      detailEmpty: document.getElementById('detailEmpty'),
      detailContent: document.getElementById('detailContent'),
      bookCount: document.getElementById('bookCount'),
      categoryCount: document.getElementById('categoryCount'),
      totalSize: document.getElementById('totalSize'),
      modeText: document.getElementById('modeText'),
      recentCount: document.getElementById('recentCount'),
      recentList: document.getElementById('recentList'),
      recentCard: document.getElementById('recentCard'),
      recentToggle: document.getElementById('recentToggle'),
      readerOverlay: document.getElementById('readerOverlay'),
      readerTitle: document.getElementById('readerTitle'),
      readerBody: document.getElementById('readerBody'),
      fontDown: document.getElementById('fontDown'),
      fontUp: document.getElementById('fontUp'),
      bgSelect: document.getElementById('bgSelect'),
      toggleFullscreen: document.getElementById('toggleFullscreen'),
      closeReader: document.getElementById('closeReader')
    };

    if (!('showDirectoryPicker' in window)) {
      el.pickModern.title = '当前浏览器可能不支持 showDirectoryPicker，请使用兼容方式导入';
    }

    applyTheme(state.theme, false);


    function loadJson(key, fallback) {
      try {
        const raw = localStorage.getItem(key);
        return raw ? JSON.parse(raw) : fallback;
      } catch (_) {
        return fallback;
      }
    }

    function saveJson(key, value) {
      try {
        localStorage.setItem(key, JSON.stringify(value));
      } catch (_) {}
    }

    function saveReaderPrefs() {
      saveJson(STORAGE_KEYS.readerPrefs, state.readerPrefs);
    }

    function saveProgress() {
      saveJson(STORAGE_KEYS.progress, state.progress);
    }

    function saveRecents() {
      saveJson(STORAGE_KEYS.recents, state.recents);
    }

    function saveCategoryWidths() {
      saveJson(STORAGE_KEYS.categoryWidths, state.categoryWidths);
    }

    function saveShelfView() {
      saveJson(STORAGE_KEYS.shelfView, state.shelfView);
    }

    function saveTheme() {
      saveJson(STORAGE_KEYS.theme, state.theme);
    }

    function applyTheme(theme = state.theme, shouldSave = false) {
      state.theme = theme === 'night' ? 'night' : 'day';
      document.body.classList.toggle('night-mode', state.theme === 'night');
      if (el.themeToggle) {
        const isNight = state.theme === 'night';
        el.themeToggle.setAttribute('aria-pressed', String(isNight));
        el.themeIcon.textContent = isNight ? '☀' : '☾';
        el.themeText.textContent = isNight ? '日模式' : '夜模式';
        el.themeToggle.title = isNight ? '切换到日模式' : '切换到夜模式';
      }
      if (shouldSave) saveTheme();
    }

    function toggleTheme() {
      applyTheme(state.theme === 'night' ? 'day' : 'night', true);
    }

    function openHelp() {
      state.helpOpen = true;
      el.helpOverlay.classList.add('open');
    }

    function closeHelpPanel() {
      state.helpOpen = false;
      el.helpOverlay.classList.remove('open');
    }

    function setRecentOpen(open) {
      state.recentOpen = Boolean(open);
      if (!el.recentCard || !el.recentToggle) return;
      el.recentCard.classList.toggle('open', state.recentOpen);
      el.recentCard.classList.toggle('collapsed', !state.recentOpen);
      el.recentToggle.setAttribute('aria-expanded', String(state.recentOpen));
    }

    function toggleRecent() {
      setRecentOpen(!state.recentOpen);
    }

    function progressTextForBook(book) {
      const progress = state.progress[book.key];
      if (!progress) return '未记录进度';
      if (typeof progress.percentage === 'number') return `读到 ${Math.max(0, Math.min(100, Math.round(progress.percentage)))}%`;
      if (progress.chapter) return `读到 ${progress.chapter}`;
      if (typeof progress.scrollPercent === 'number') return `读到 ${Math.round(progress.scrollPercent)}%`;
      return '已保存位置';
    }

    function addRecent(book) {
      const old = state.recents.filter(item => item.key !== book.key);
      state.recents = [{
        key: book.key,
        title: book.title,
        category: book.category,
        ext: book.ext,
        size: book.size,
        updatedAt: Date.now(),
        progressText: progressTextForBook(book)
      }, ...old].slice(0, 12);
      saveRecents();
      renderRecent();
    }

    function updateBookProgress(book, patch) {
      if (!book || !book.key) return;
      state.progress[book.key] = {
        ...(state.progress[book.key] || {}),
        ...patch,
        updatedAt: Date.now()
      };
      saveProgress();
      const recent = state.recents.find(item => item.key === book.key);
      if (recent) {
        recent.updatedAt = Date.now();
        recent.progressText = progressTextForBook(book);
        saveRecents();
        renderRecent();
      }
    }

    function renderRecent() {
      if (!el.recentList) return;
      const items = [...state.recents].sort((a, b) => b.updatedAt - a.updatedAt).slice(0, 6);
      el.recentCount.textContent = `${items.length} 本`;
      if (!items.length) {
        el.recentList.innerHTML = '<div class="recent-meta">导入并打开书籍后，这里会显示最近阅读记录。</div>';
        return;
      }
      el.recentList.innerHTML = '';
      items.forEach(item => {
        const book = state.books.find(candidate => candidate.key === item.key);
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'recent-item';
        button.innerHTML = `
          <span class="recent-name">${escapeHtml(item.title)}</span>
          <span class="recent-meta">${escapeHtml(item.ext.toUpperCase())} · ${escapeHtml(item.category)} · ${escapeHtml(item.progressText || '已记录')}</span>
        `;
        if (book) {
          button.addEventListener('click', () => {
            state.selectedBookId = book.id;
            state.selectedCategory = '全部';
            render();
            renderBookDetail(book);
            openReader(book, 'direct');
          });
        } else {
          button.disabled = true;
          button.title = '重新导入包含这本书的文件夹后才能继续阅读';
        }
        el.recentList.appendChild(button);
      });
    }

    function applyReaderPreferences() {
      const theme = READ_THEMES[state.readerPrefs.bg] || READ_THEMES.paper;
      el.readerBody.style.setProperty('--read-bg', theme.bg);
      el.readerBody.style.setProperty('--read-text', theme.text);
      el.readerBody.style.setProperty('--read-font-size', `${state.readerPrefs.fontSize}px`);
      el.bgSelect.value = state.readerPrefs.bg;
      if (state.epubRendition && state.epubRendition.themes) {
        try {
          state.epubRendition.themes.fontSize(`${state.readerPrefs.fontSize}px`);
          state.epubRendition.themes.override('background', theme.bg);
          state.epubRendition.themes.override('color', theme.text);
        } catch (_) {}
      }
    }

    function changeFontSize(delta) {
      state.readerPrefs.fontSize = Math.max(14, Math.min(30, state.readerPrefs.fontSize + delta));
      saveReaderPrefs();
      applyReaderPreferences();
    }

    function setReaderBg(bg) {
      state.readerPrefs.bg = READ_THEMES[bg] ? bg : 'paper';
      saveReaderPrefs();
      applyReaderPreferences();
    }

    function extOf(name) {
      const index = name.lastIndexOf('.');
      return index === -1 ? '' : name.slice(index + 1).toLowerCase();
    }

    function titleOf(name) {
      return name.replace(/\.[^.]+$/, '').replace(/[_-]+/g, ' ').trim();
    }

    function categoryOf(relativePath) {
      const parts = relativePath.split('/').filter(Boolean);
      if (parts.length > 1) return parts[0];
      return '未分类';
    }

    function folderPathOf(book) {
      const parts = String(book.relativePath || '').split('/').filter(Boolean);
      parts.pop();
      return parts.length ? parts.join('/') : '根目录';
    }

    function displayPathOf(book) {
      const root = book.rootName || state.rootName || '导入根目录';
      return `${root}/${book.relativePath}`;
    }

    function normalizeImportedPath(rawPath, commonRoot = '') {
      const parts = String(rawPath || '').split('/').filter(Boolean);
      if (commonRoot && parts.length > 1 && parts[0] === commonRoot) return parts.slice(1).join('/');
      return parts.join('/');
    }

    function bytesToSize(bytes) {
      if (!bytes) return '0 MB';
      const units = ['B', 'KB', 'MB', 'GB'];
      let value = bytes;
      let idx = 0;
      while (value >= 1024 && idx < units.length - 1) {
        value /= 1024;
        idx += 1;
      }
      return `${value.toFixed(value >= 10 || idx === 0 ? 0 : 1)} ${units[idx]}`;
    }

    function spineHeight(size, title = '') {
      const mb = Math.max(0.1, size / 1024 / 1024);
      const sizeHeight = 105 + Math.log2(mb + 1) * 24;
      const titleBoost = Math.min(26, Math.max(0, String(title).length - 12) * 1.1);
      return Math.max(118, Math.min(230, sizeHeight + titleBoost));
    }

    function spineWidth(title) {
      const hasLatin = /[A-Za-z0-9]/.test(title);
      const base = hasLatin ? 46 : 40;
      return Math.max(40, Math.min(66, base + Math.min(String(title).length, 20) * 0.9));
    }

    function spineFontBase(title, height) {
      const length = Array.from(String(title || '')).length;
      if (length <= 8) return 15;
      if (length <= 14) return 14;
      if (length <= 22) return 12.5;
      if (height < 150) return 10.5;
      return 11.5;
    }

    function colorIndexForBook(title, category = '', ext = '') {
      const text = `${title} ${category} ${ext}`.toLowerCase();
      const contains = list => list.some(word => text.includes(word));
      if (contains(['安全', '考核', '通知', '评优', '纪律', '制度', '申请', '截止', '公示', '警示', '政策'])) return 0;
      if (contains(['课程', '教学', '教案', '讲义', '报名', '表', '作业', '学习', '考试', '课堂', '模板'])) return 1;
      if (contains(['实验', '科研', '自然', '物理', '技术', '项目', '方案', '方法', '数据', '程序', '代码', '谱', '分析'])) return 2;
      if (contains(['学校', '学院', '班级', '资料', '公文', '汇总', '名单', '记录', '档案', '年级', '行政'])) return 3;
      if (contains(['心理', '文学', '阅读', '随笔', '总结', '诗', '哲学', '人文', '拓展'])) return 4;
      const fallback = (Array.from(title + category).reduce((acc, ch) => acc + ch.charCodeAt(0), 0)) % 5;
      return fallback;
    }

    function colorMetaForBook(title, category = '', ext = '') {
      const index = colorIndexForBook(title, category, ext);
      return { index, ...prismPalette[index] };
    }

    async function walkDirectoryHandle(dirHandle, prefix = '') {
      const results = [];
      for await (const [name, handle] of dirHandle.entries()) {
        const rel = prefix ? `${prefix}/${name}` : name;
        if (handle.kind === 'directory') {
          const children = await walkDirectoryHandle(handle, rel);
          results.push(...children);
        } else if (handle.kind === 'file') {
          const file = await handle.getFile();
          const ext = extOf(file.name);
          if (SUPPORTED_EXT.has(ext)) {
            results.push(makeBook(file, rel, handle));
          }
        }
      }
      return results;
    }

    function makeBook(file, relativePath, handle = null) {
      const ext = extOf(file.name);
      const title = titleOf(file.name);
      const category = categoryOf(relativePath);
      const colorMeta = colorMetaForBook(title, category, ext);
      return {
        id: `${relativePath}-${file.size}-${file.lastModified || Date.now()}-${Math.random().toString(36).slice(2)}`,
        key: `${relativePath}::${file.size}`,
        title,
        fileName: file.name,
        ext,
        category,
        relativePath,
        size: file.size,
        lastModified: file.lastModified || Date.now(),
        file,
        handle,
        color: colorMeta.hex,
        colorIndex: colorMeta.index,
        colorName: colorMeta.name
      };
    }

    async function importWithModernPicker() {
      if (!('showDirectoryPicker' in window)) {
        el.directoryInput.click();
        return;
      }
      try {
        const dirHandle = await window.showDirectoryPicker({ mode: 'read' });
        el.modeText.textContent = '扫描中';
        const books = await walkDirectoryHandle(dirHandle);
        setBooks(books, '现代导入', dirHandle.name || '导入根目录');
      } catch (error) {
        if (error && error.name !== 'AbortError') {
          alert('导入失败：' + error.message);
        }
      }
    }

    function importWithFileInput(files) {
      const fileList = Array.from(files);
      const rawPaths = fileList.map(file => file.webkitRelativePath || file.name);
      const firstParts = rawPaths
        .map(path => String(path).split('/').filter(Boolean)[0])
        .filter(Boolean);
      const commonRoot = firstParts.length && firstParts.every(part => part === firstParts[0]) ? firstParts[0] : '';
      const books = fileList
        .filter(file => SUPPORTED_EXT.has(extOf(file.name)))
        .map(file => makeBook(file, normalizeImportedPath(file.webkitRelativePath || file.name, commonRoot)));
      setBooks(books, '兼容导入', commonRoot || '导入根目录');
    }

    function setBooks(books, mode, rootName = '导入根目录') {
      state.rootName = rootName;
      state.books = books.map(book => ({ ...book, rootName }));
      state.selectedCategory = '全部';
      state.selectedBookId = null;
      el.modeText.textContent = mode;
      state.prismClickFocus = null;
      if (state.books[0]) setVisualFocus(state.books[0].colorIndex, state.books[0].color);
      else setVisualFocus(0, prismPalette[0].hex);
      render();
    }

