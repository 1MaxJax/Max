    function clearLibrary() {
      state.books = [];
      state.selectedBookId = null;
      state.selectedCategory = '全部';
      state.search = '';
      state.prismClickFocus = null;
      el.searchInput.value = '';
      el.modeText.textContent = '待导入';
      setVisualFocus(0, prismPalette[0].hex);
      render();
    }

    function getCategories() {
      return Array.from(new Set(state.books.map(book => book.category))).sort((a, b) => a.localeCompare(b, 'zh-CN'));
    }

    function getFilteredBooks() {
      let books = [...state.books];
      const q = state.search.trim().toLowerCase();
      if (state.selectedCategory !== '全部') books = books.filter(book => book.category === state.selectedCategory);
      if (q) {
        books = books.filter(book => [book.title, book.ext, book.category, book.relativePath].join(' ').toLowerCase().includes(q));
      }
      books.sort((a, b) => {
        if (state.sort === 'size-desc') return b.size - a.size;
        if (state.sort === 'size-asc') return a.size - b.size;
        if (state.sort === 'ext') return a.ext.localeCompare(b.ext) || a.title.localeCompare(b.title, 'zh-CN');
        return a.title.localeCompare(b.title, 'zh-CN');
      });
      return books;
    }

    function groupByCategory(books) {
      const groups = new Map();
      books.forEach(book => {
        if (!groups.has(book.category)) groups.set(book.category, []);
        groups.get(book.category).push(book);
      });
      return Array.from(groups.entries()).sort((a, b) => a[0].localeCompare(b[0], 'zh-CN'));
    }

    function renderStats() {
      const total = state.books.reduce((sum, book) => sum + book.size, 0);
      el.bookCount.textContent = state.books.length;
      el.categoryCount.textContent = getCategories().length;
      el.totalSize.textContent = bytesToSize(total);
    }

    function renderCategories() {
      const categories = ['全部', ...getCategories()];
      el.categoryBar.innerHTML = '';
      categories.forEach(category => {
        const count = category === '全部' ? state.books.length : state.books.filter(book => book.category === category).length;
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'chip' + (state.selectedCategory === category ? ' active' : '');
        button.textContent = `${category} · ${count}`;
        button.addEventListener('click', () => {
          state.selectedCategory = category;
          const first = category === '全部' ? state.books[0] : state.books.find(book => book.category === category);
          if (first) { state.prismClickFocus = null; setVisualFocus(first.colorIndex, first.color); }
          render();
        });
        el.categoryBar.appendChild(button);
      });
    }

    let shelfScrollSyncing = false;

    function hideShelfTopScrollbar() {
      if (!el.shelfTopScrollbar) return;
      el.shelfTopScrollbar.classList.remove('visible');
      if (el.shelfTopScrollbarInner) el.shelfTopScrollbarInner.style.width = '1px';
    }

    function updateShelfTopScrollbar() {
      if (!el.shelfTopScrollbar || !el.shelfTopScrollbarInner || !el.shelfWrapper) return;
      const shouldShow = state.shelfView === 'columns' && el.shelfWrapper.scrollWidth > el.shelfWrapper.clientWidth + 4;
      el.shelfTopScrollbar.classList.toggle('visible', shouldShow);
      if (!shouldShow) {
        el.shelfTopScrollbarInner.style.width = '1px';
        return;
      }
      el.shelfTopScrollbarInner.style.width = `${el.shelfWrapper.scrollWidth}px`;
      if (!shelfScrollSyncing) {
        shelfScrollSyncing = true;
        el.shelfTopScrollbar.scrollLeft = el.shelfWrapper.scrollLeft;
        window.requestAnimationFrame(() => { shelfScrollSyncing = false; });
      }
    }

    function renderShelves() {
      const books = getFilteredBooks();
      el.shelfWrapper.innerHTML = '';
      el.shelfWrapper.classList.toggle('columns-view', state.shelfView === 'columns');
      hideShelfTopScrollbar();
      if (!state.books.length) {
        el.shelfWrapper.innerHTML = `<div class="empty-panel"><strong>还没有书架</strong><br>点击“选择文件夹”导入本地电子书，或先载入示例书架。</div>`;
        return;
      }
      if (!books.length) {
        el.shelfWrapper.innerHTML = `<div class="empty-panel"><strong>没有匹配结果</strong><br>换一个关键词，或者切换到“全部”分类。</div>`;
        return;
      }

      const groups = state.selectedCategory === '全部' ? groupByCategory(books) : [[state.selectedCategory, books]];
      groups.forEach(([category, groupBooks]) => {
        const section = document.createElement('section');
        const isColumns = state.shelfView === 'columns';
        section.className = 'shelf-section' + (isColumns ? ' column-mode' : '');
        const storedWidth = Number(state.categoryWidths[category] || 240);
        const width = Math.max(180, Math.min(420, storedWidth));
        if (isColumns) {
          section.style.setProperty('--section-width', `${width}px`);
          section.style.setProperty('--section-accent', groupBooks[0]?.color || prismPalette[0].hex);
        }
        section.innerHTML = `
          <div class="shelf-head">
            <h2>${escapeHtml(category)}</h2>
            <span class="shelf-count">${groupBooks.length} 本</span>
          </div>
          ${isColumns ? `
            <div class="width-control" aria-label="${escapeHtml(category)} 最适宽度控制">
              <button class="fit-width-btn" type="button" title="一键最适宽度" aria-label="${escapeHtml(category)} 一键最适宽度">
                <span class="fit-icon-mark" aria-hidden="true"></span>
              </button>
            </div>` : ''}
          <div class="shelf-line" role="list"></div>
        `;
        section.dataset.category = category;
        const line = section.querySelector('.shelf-line');
        groupBooks.forEach(book => line.appendChild(createBookButton(book, isColumns)));
        el.shelfWrapper.appendChild(section);
      });
      if (state.shelfView === 'columns') initWidthControls();
      window.requestAnimationFrame(() => {
        fitSpineTitles();
        updateShelfTopScrollbar();
      });
    }

    function fitSpineTitles() {
      document.querySelectorAll('.spine-title').forEach(title => {
        const base = Number(title.dataset.baseFont || 14);
        const min = 8;
        let size = base;
        title.classList.remove('too-long');
        title.style.fontSize = `${size}px`;
        while (size > min && (title.scrollHeight > title.clientHeight + 1 || title.scrollWidth > title.clientWidth + 1)) {
          size -= 0.5;
          title.style.fontSize = `${size}px`;
        }
        if (title.scrollHeight > title.clientHeight + 1 || title.scrollWidth > title.clientWidth + 1) {
          title.classList.add('too-long');
          title.title = title.textContent;
        }
      });
    }

    function createBookButton(book, isColumns = false) {
      const button = document.createElement('button');
      button.type = 'button';
      const height = isColumns
        ? Math.max(54, Math.min(86, 44 + Math.ceil(Array.from(String(book.title || '')).length / 10) * 12))
        : spineHeight(book.size, book.title);
      const width = isColumns ? '100%' : `${spineWidth(book.title)}px`;
      const baseFont = isColumns ? 13 : spineFontBase(book.title, height);
      button.className = 'book-spine' + (state.selectedBookId === book.id ? ' active' : '');
      button.style.setProperty('--h', `${height}px`);
      if (!isColumns) button.style.setProperty('--w', width);
      button.style.setProperty('--spine-font-size', `${baseFont}px`);
      button.style.setProperty('--book-color', book.color);
      button.setAttribute('role', 'listitem');
      button.setAttribute('aria-label', `选择 ${book.title}`);
      button.title = `${book.title} · ${book.category} · ${book.ext.toUpperCase()}`;
      button.innerHTML = `
        <span class="spine-title" data-base-font="${baseFont}">${escapeHtml(book.title)}</span>
        <span class="spine-ext">${escapeHtml(book.ext.toUpperCase())}</span>
      `;
      button.addEventListener('click', () => {
        state.selectedBookId = book.id;
        state.prismClickFocus = null;
        setVisualFocus(book.colorIndex, book.color);
        render();
        renderBookDetail(book);
      });
      button.addEventListener('pointerenter', () => setVisualFocus(book.colorIndex, book.color));
      button.addEventListener('pointerleave', () => {
        const selected = state.books.find(candidate => candidate.id === state.selectedBookId);
        if (selected) setVisualFocus(selected.colorIndex, selected.color);
        else if (state.books[0]) setVisualFocus(state.books[0].colorIndex, state.books[0].color);
        else setVisualFocus(0, prismPalette[0].hex);
      });
      return button;
    }

    function optimalCategoryWidth(books) {
      if (!books || !books.length) return 220;
      const longest = books.reduce((max, book) => Math.max(max, Array.from(String(book.title || '')).length), 0);
      const latinBoost = books.some(book => /[A-Za-z0-9]/.test(book.title)) ? 24 : 0;
      const densityBoost = books.length >= 8 ? 20 : books.length >= 4 ? 10 : 0;
      return Math.max(190, Math.min(420, 172 + longest * 5.6 + latinBoost + densityBoost));
    }

    function setSectionWidth(section, category, width, shouldSave = true) {
      const next = Math.max(180, Math.min(420, Number(width) || 240));
      section.style.setProperty('--section-width', `${next}px`);
      state.categoryWidths[category] = next;
      if (shouldSave) saveCategoryWidths();
      window.requestAnimationFrame(fitSpineTitles);
    }

    function initWidthControls() {
      el.shelfWrapper.querySelectorAll('.shelf-section.column-mode').forEach(section => {
        const category = section.dataset.category || section.querySelector('.shelf-head h2')?.textContent.trim() || '';
        const fitButton = section.querySelector('.fit-width-btn');
        if (!category || !fitButton) return;
        fitButton.addEventListener('click', () => {
          const books = state.books.filter(book => book.category === category);
          const target = optimalCategoryWidth(books);
          setSectionWidth(section, category, target, true);
          fitButton.animate([
            { transform: 'translateY(0) rotate(0deg) scale(1)' },
            { transform: 'translateY(-3px) rotate(-5deg) scale(1.08)' },
            { transform: 'translateY(0) rotate(0deg) scale(1)' }
          ], { duration: 420, easing: 'cubic-bezier(.2,.9,.2,1.2)' });
        });
      });
    }

    function renderBookDetail(book) {
      el.detailEmpty.classList.add('hidden');
      el.detailContent.classList.remove('hidden');
      el.detailContent.innerHTML = `
        <div class="cover-stage">
          <div class="book-cover" style="--cover-color: ${book.color}">
            <div class="cover-title">${escapeHtml(book.title)}</div>
            <div class="cover-ext">${escapeHtml(book.ext.toUpperCase())} · ${escapeHtml(book.category)}</div>
          </div>
        </div>
        <h2 class="detail-title">${escapeHtml(book.title)}</h2>
        <div class="meta-list">
          <div class="meta-item"><b>分类</b><span>${escapeHtml(book.category)}</span></div>
          <div class="meta-item"><b>格式</b><span>${escapeHtml(book.ext.toUpperCase())}</span></div>
          <div class="meta-item"><b>大小</b><span>${bytesToSize(book.size)}</span></div>
          <div class="meta-item"><b>进度</b><span>${escapeHtml(progressTextForBook(book))}</span></div>
        </div>
        <div class="reader-choice">
          <button id="openReaderDirect" class="secondary" type="button">直接查看</button>
          <button id="openReaderFullscreen" class="primary" type="button">全屏阅读</button>
        </div>
      `;
      document.getElementById('openReaderDirect').addEventListener('click', () => openReader(book, 'direct'));
      document.getElementById('openReaderFullscreen').addEventListener('click', () => openReader(book, 'fullscreen'));
    }

    async function openReader(book, mode = 'direct') {
      el.readerTitle.textContent = book.title;
      cleanupReaderResources();
      state.currentReaderBook = book;
      state.currentReaderKind = book.ext;
      el.readerOverlay.classList.add('open');
      el.readerOverlay.classList.toggle('fullscreen', mode === 'fullscreen');
      el.toggleFullscreen.textContent = mode === 'fullscreen' ? '退出全屏' : '全屏';
      applyReaderPreferences();
      addRecent(book);
      setReaderLoading(`正在打开 ${book.ext.toUpperCase()} 文件……`);

      try {
        if (book.ext === 'pdf') {
          openPdfReader(book);
        } else if (book.ext === 'txt' || book.ext === 'md') {
          await openTextReader(book);
        } else if (book.ext === 'epub') {
          await openEpubReader(book);
        } else if (book.ext === 'docx') {
          await openDocxReader(book);
        } else if (book.ext === 'mobi' || book.ext === 'azw3') {
          openMobiFallback(book);
        } else {
          showReaderNotice(`${escapeHtml(book.ext.toUpperCase())} 暂不支持阅读。`);
        }
      } catch (error) {
        showReaderError(error, book);
      }
    }

    function openPdfReader(book) {
      const url = createTrackedObjectUrl(book.file);
      const object = document.createElement('object');
      object.type = 'application/pdf';
      object.data = url;
      object.innerHTML = `<div class="notice">当前浏览器不能内嵌显示 PDF。你可以换用 Chrome / Edge，或在后续版本接入 PDF.js。</div>`;
      el.readerBody.innerHTML = '';
      el.readerBody.appendChild(object);
    }

    async function openTextReader(book) {
      const text = await book.file.text();
      const pre = document.createElement('div');
      pre.className = 'text-reader';
      pre.textContent = text;
      el.readerBody.innerHTML = '';
      el.readerBody.appendChild(pre);
      restoreScrollableProgress(pre, book);
      bindScrollableProgress(pre, book, 'text');
    }

    async function openEpubReader(book) {
      if (typeof ePub === 'undefined') {
        throw new Error('EPUB 阅读库没有加载成功。请确认电脑可以联网，或后续改成本地离线依赖。');
      }

      const arrayBuffer = await book.file.arrayBuffer();
      el.readerBody.innerHTML = `
        <div class="epub-shell">
          <div class="reader-tools">
            <button id="epubPrev" class="ghost" type="button">上一页</button>
            <button id="epubNext" class="ghost" type="button">下一页</button>
            <select id="epubToc" class="select" aria-label="EPUB 目录"><option value="">正在读取目录……</option></select>
            <span id="epubStatus" class="reader-status">EPUB</span>
          </div>
          <div id="epubViewer" class="epub-viewer"></div>
        </div>
      `;
      applyReaderPreferences();

      state.epubBook = ePub(arrayBuffer);
      state.epubRendition = state.epubBook.renderTo('epubViewer', {
        width: '100%',
        height: '100%',
        spread: 'none',
        flow: 'paginated'
      });
      applyReaderPreferences();

      const tocSelect = document.getElementById('epubToc');
      const status = document.getElementById('epubStatus');
      document.getElementById('epubPrev').addEventListener('click', () => state.epubRendition.prev());
      document.getElementById('epubNext').addEventListener('click', () => state.epubRendition.next());

      await state.epubBook.ready;
      const navigation = await state.epubBook.loaded.navigation;
      const toc = flattenToc(navigation.toc || []);
      tocSelect.innerHTML = '';
      if (toc.length) {
        toc.forEach(item => {
          const option = document.createElement('option');
          option.value = item.href;
          option.textContent = `${'　'.repeat(item.level)}${item.label}`;
          tocSelect.appendChild(option);
        });
        tocSelect.addEventListener('change', event => {
          if (event.target.value) state.epubRendition.display(event.target.value);
        });
      } else {
        tocSelect.innerHTML = '<option value="">未检测到目录</option>';
      }

      state.epubRendition.on('relocated', location => {
        const start = location && location.start ? location.start : {};
        const percentRaw = typeof start.percentage === 'number' ? start.percentage * 100 : null;
        const chapter = findChapterLabel(toc, start.href);
        const pageInfo = start.displayed && start.displayed.total
          ? `本章 ${start.displayed.page}/${start.displayed.total}`
          : '';
        const pieces = [];
        if (chapter) pieces.push(chapter);
        if (typeof percentRaw === 'number') pieces.push(`${Math.round(percentRaw)}%`);
        if (pageInfo) pieces.push(pageInfo);
        status.textContent = pieces.join(' · ') || 'EPUB';
        updateBookProgress(book, {
          type: 'epub',
          cfi: start.cfi || null,
          href: start.href || null,
          chapter,
          percentage: typeof percentRaw === 'number' ? Math.round(percentRaw) : undefined,
          pageInfo,
          progressText: pieces.join(' · ') || '已保存位置'
        });
        if (start.href) {
          const current = toc.find(item => normalizeHref(item.href) === normalizeHref(start.href));
          if (current) tocSelect.value = current.href;
        }
      });

      const saved = state.progress[book.key];
      try {
        if (saved && saved.cfi) {
          await state.epubRendition.display(saved.cfi);
        } else {
          await state.epubRendition.display();
        }
      } catch (_) {
        await state.epubRendition.display();
      }
    }

    async function openDocxReader(book) {
      if (typeof mammoth === 'undefined') {
        throw new Error('DOCX 阅读库没有加载成功。请确认电脑可以联网，或后续改成本地离线依赖。');
      }

      const arrayBuffer = await book.file.arrayBuffer();
      const result = await mammoth.convertToHtml({ arrayBuffer });
      const warnings = result.messages && result.messages.length
        ? `<div class="docx-warnings">转换提示：${escapeHtml(result.messages.map(msg => msg.message).join('；'))}</div>`
        : '';
      el.readerBody.innerHTML = `
        ${warnings}
        <article id="docxReaderArticle" class="docx-reader">${result.value || '<p>这个 DOCX 没有可预览的正文内容。</p>'}</article>
      `;
      applyReaderPreferences();
      const article = document.getElementById('docxReaderArticle');
      restoreScrollableProgress(article, book);
      bindScrollableProgress(article, book, 'docx');
    }

    function openMobiFallback(book) {
      const url = createTrackedObjectUrl(book.file);
      el.readerBody.innerHTML = `
        <div class="notice">
          <strong>${escapeHtml(book.ext.toUpperCase())} 已识别，但网页版暂不直接解析正文。</strong><br>
          MOBI / AZW3 属于 Kindle 旧格式，浏览器端缺少稳定通用阅读内核；很多文件还可能包含私有压缩、旧版排版或 DRM 限制。当前先保留“书架管理 + 外部打开”的能力。
          <div class="mobi-actions">
            <a class="primary" href="${url}" download="${escapeHtml(book.fileName)}">下载 / 用本机阅读器打开</a>
          </div>
          <p style="margin-top:14px;">后续如果要完整支持 MOBI，建议路线是：前端书架保持不变，增加一个本地转换步骤，把 MOBI / AZW3 转成 EPUB 或 HTML 后再阅读。</p>
        </div>
      `;
    }

    function flattenToc(items, level = 0, output = []) {
      items.forEach(item => {
        output.push({ label: item.label || '未命名章节', href: item.href, level });
        if (item.subitems && item.subitems.length) flattenToc(item.subitems, level + 1, output);
      });
      return output;
    }

    function normalizeHref(href = '') {
      return String(href).split('#')[0].replace(/^\.\//, '');
    }

    function findChapterLabel(toc, href) {
      if (!href || !toc || !toc.length) return '';
      const normalized = normalizeHref(href);
      const exact = toc.find(item => normalizeHref(item.href) === normalized);
      if (exact) return exact.label;
      const loose = toc.find(item => normalized.endsWith(normalizeHref(item.href)) || normalizeHref(item.href).endsWith(normalized));
      return loose ? loose.label : '';
    }

    function bindScrollableProgress(node, book, type) {
      if (!node) return;
      let timer = null;
      node.addEventListener('scroll', () => {
        if (timer) window.clearTimeout(timer);
        timer = window.setTimeout(() => {
          const max = Math.max(1, node.scrollHeight - node.clientHeight);
          const percent = Math.max(0, Math.min(100, node.scrollTop / max * 100));
          updateBookProgress(book, {
            type,
            scrollPercent: percent,
            percentage: Math.round(percent),
            progressText: `读到 ${Math.round(percent)}%`
          });
        }, 180);
      });
    }

    function restoreScrollableProgress(node, book) {
      if (!node) return;
      const saved = state.progress[book.key];
      if (!saved || typeof saved.scrollPercent !== 'number') return;
      window.requestAnimationFrame(() => {
        const max = Math.max(0, node.scrollHeight - node.clientHeight);
        node.scrollTop = max * Math.max(0, Math.min(100, saved.scrollPercent)) / 100;
      });
    }

    function setReaderLoading(message) {
      el.readerBody.innerHTML = `<div class="reader-loading">${escapeHtml(message)}</div>`;
    }

    function showReaderNotice(message) {
      el.readerBody.innerHTML = `<div class="notice">${message}</div>`;
    }

    function showReaderError(error, book) {
      const message = error && error.message ? error.message : String(error);
      el.readerBody.innerHTML = `
        <div class="notice">
          <strong>打开《${escapeHtml(book.title)}》失败。</strong><br>
          ${escapeHtml(message)}<br><br>
          如果你打开的是“示例书架”，示例文件只是占位文件，不能真正解析；请导入真实 EPUB / DOCX 文件测试。
        </div>
      `;
    }

    function createTrackedObjectUrl(file) {
      const url = URL.createObjectURL(file);
      state.objectUrl = url;
      state.objectUrls.push(url);
      return url;
    }

    function cleanupReaderResources() {
      if (state.epubRendition && typeof state.epubRendition.destroy === 'function') {
        try { state.epubRendition.destroy(); } catch (_) {}
      }
      if (state.epubBook && typeof state.epubBook.destroy === 'function') {
        try { state.epubBook.destroy(); } catch (_) {}
      }
      state.epubRendition = null;
      state.epubBook = null;
      state.currentReaderBook = null;
      state.currentReaderKind = null;
      state.objectUrls.forEach(url => URL.revokeObjectURL(url));
      state.objectUrls = [];
      state.objectUrl = null;
      el.readerBody.innerHTML = '';
    }

    function closeReader() {
      el.readerOverlay.classList.remove('open');
      el.readerOverlay.classList.remove('fullscreen');
      cleanupReaderResources();
    }

    function toggleReaderFullscreen() {
      const next = !el.readerOverlay.classList.contains('fullscreen');
      el.readerOverlay.classList.toggle('fullscreen', next);
      el.toggleFullscreen.textContent = next ? '退出全屏' : '全屏';
      if (state.epubRendition && typeof state.epubRendition.resize === 'function') {
        window.setTimeout(() => {
          try { state.epubRendition.resize(); } catch (_) {}
        }, 80);
      }
    }

    function renderViewSwitch() {
      el.viewRows.classList.toggle('active', state.shelfView === 'rows');
      el.viewColumns.classList.toggle('active', state.shelfView === 'columns');
    }

    function render() {
      renderStats();
      renderViewSwitch();
      const focused = state.books.find(book => book.id === state.selectedBookId) || state.books[0];
      if (state.prismClickFocus !== null) setVisualFocus(state.prismClickFocus, prismPalette[state.prismClickFocus]?.hex || '#7755b2');
      else if (focused) setVisualFocus(focused.colorIndex, focused.color);
      else setVisualFocus(0, prismPalette[0].hex);
      renderCategories();
      renderShelves();
      renderRecent();
      window.requestAnimationFrame(updateShelfTopScrollbar);
      const selected = state.books.find(book => book.id === state.selectedBookId);
      if (!selected) {
        el.detailContent.classList.add('hidden');
        el.detailEmpty.classList.remove('hidden');
      }
    }

    function escapeHtml(text) {
      return String(text)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    el.shelfTopScrollbar.addEventListener('scroll', () => {
      if (shelfScrollSyncing) return;
      shelfScrollSyncing = true;
      el.shelfWrapper.scrollLeft = el.shelfTopScrollbar.scrollLeft;
      window.requestAnimationFrame(() => { shelfScrollSyncing = false; });
    });

    el.shelfWrapper.addEventListener('scroll', () => {
      if (shelfScrollSyncing) return;
      shelfScrollSyncing = true;
      el.shelfTopScrollbar.scrollLeft = el.shelfWrapper.scrollLeft;
      window.requestAnimationFrame(() => { shelfScrollSyncing = false; });
    });

    window.addEventListener('resize', () => window.requestAnimationFrame(updateShelfTopScrollbar));

    el.pickModern.addEventListener('click', importWithModernPicker);
    el.pickFallback.addEventListener('click', () => el.directoryInput.click());
    el.directoryInput.addEventListener('change', event => importWithFileInput(event.target.files));
    el.loadDemo.addEventListener('click', loadDemo);
    el.clearLibrary.addEventListener('click', clearLibrary);
    el.themeToggle.addEventListener('click', toggleTheme);
    el.helpButton.addEventListener('click', openHelp);
    el.closeHelp.addEventListener('click', closeHelpPanel);
    el.helpOverlay.addEventListener('click', event => {
      if (event.target === el.helpOverlay) closeHelpPanel();
    });
    el.recentToggle.addEventListener('click', toggleRecent);
    el.recentToggle.addEventListener('keydown', event => {
      if (event.key === 'Enter' || event.key === ' ') {
        event.preventDefault();
        toggleRecent();
      }
    });
    el.searchInput.addEventListener('input', event => {
      state.search = event.target.value;
      render();
    });
    el.sortSelect.addEventListener('change', event => {
      state.sort = event.target.value;
      render();
    });
    el.viewRows.addEventListener('click', () => {
      state.shelfView = 'rows';
      saveShelfView();
      render();
    });
    el.viewColumns.addEventListener('click', () => {
      state.shelfView = 'columns';
      saveShelfView();
      render();
    });
    el.showAll.addEventListener('click', () => {
      state.selectedCategory = '全部';
      render();
    });
    el.fontDown.addEventListener('click', () => changeFontSize(-2));
    el.fontUp.addEventListener('click', () => changeFontSize(2));
    el.bgSelect.value = state.readerPrefs.bg;
    el.bgSelect.addEventListener('change', event => setReaderBg(event.target.value));
    el.toggleFullscreen.addEventListener('click', toggleReaderFullscreen);
    el.closeReader.addEventListener('click', closeReader);
    el.readerOverlay.addEventListener('click', event => {
      if (event.target === el.readerOverlay) closeReader();
    });
    window.addEventListener('keydown', event => {
      if (event.key === 'Escape') {
        if (state.helpOpen) closeHelpPanel();
        else closeReader();
      }
    });


    function initWaveBackground() {
      const canvas = document.getElementById('waveCanvas');
      if (!canvas || !canvas.getContext) return;
      const ctx = canvas.getContext('2d');
      const reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let width = 0;
      let height = 0;
      let dpr = 1;
      const mouse = { x: 0.50, y: 0.45, tx: 0.50, ty: 0.45 };
      const active = { index: 0, target: 0 };
      const palette = prismPalette.map(item => ({ ...parseHexColor(item.hex), hex: item.hex, name: item.name }));
      const wordMarks = [
        { row: -2, x: 0.18, phase: 0.10, size: 18 },
        { row: 1, x: 0.38, phase: 0.72, size: 22 },
        { row: 3, x: 0.62, phase: 1.40, size: 18 },
        { row: 5, x: 0.82, phase: 2.16, size: 20 }
      ];
      let frame = 0;

      function parseHexColor(hex) {
        const normalized = String(hex || '#7755b2').trim();
        const match = normalized.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
        if (!match) return { r: 119, g: 85, b: 178 };
        return {
          r: parseInt(match[1], 16),
          g: parseInt(match[2], 16),
          b: parseInt(match[3], 16)
        };
      }

      function rgbaFor(index, alpha, lift = 0) {
        const tone = palette[(index + palette.length) % palette.length];
        const r = Math.max(0, Math.min(255, Math.round(tone.r + lift)));
        const g = Math.max(0, Math.min(255, Math.round(tone.g + lift)));
        const b = Math.max(0, Math.min(255, Math.round(tone.b + lift)));
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
      }

      window.bookshelfSetWaveAccent = function updateWaveAccent(index) {
        active.target = Math.max(0, Math.min(palette.length - 1, Number(index) || 0));
      };

      function resizeWave() {
        dpr = Math.min(window.devicePixelRatio || 1, 2);
        width = window.innerWidth;
        height = window.innerHeight;
        canvas.width = Math.floor(width * dpr);
        canvas.height = Math.floor(height * dpr);
        canvas.style.width = `${width}px`;
        canvas.style.height = `${height}px`;
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }

      function wavePoint(x, row, now, baseY, gap, amplitude, viewX, viewY, skew) {
        const depth = row / 8;
        const y0 = baseY + row * gap;
        const wave = Math.sin(x * 0.0078 + now * 0.96 + row * 0.62) * amplitude;
        const slow = Math.sin(x * 0.014 - now * 0.44 + row * 0.8) * amplitude * 0.15;
        const y = y0 + wave + slow - depth * viewY * 34;
        const px = x + (depth - 0.15) * skew;
        return { x: px, y };
      }

      function waveAngle(x, row, now, baseY, gap, amplitude, viewX, viewY, skew) {
        const a = wavePoint(x - 18, row, now, baseY, gap, amplitude, viewX, viewY, skew);
        const b = wavePoint(x + 18, row, now, baseY, gap, amplitude, viewX, viewY, skew);
        return Math.atan2(b.y - a.y, b.x - a.x);
      }

      function drawPrismWord(mark, now, baseY, gap, amplitude, viewX, viewY, skew) {
        const drift = Math.sin(now * 0.48 + mark.phase) * 34 + viewX * 22;
        const x = width * mark.x + drift;
        const point = wavePoint(x, mark.row, now, baseY, gap, amplitude, viewX, viewY, skew);
        const angle = waveAngle(x, mark.row, now, baseY, gap, amplitude, viewX, viewY, skew);
        const float = Math.sin(now * 1.18 + mark.phase) * 4;
        const letters = ['p', 'r', 'i', 's', 'm'];
        const baseGap = mark.size * 0.56;
        const activeIndex = Math.round(active.index);
        ctx.save();
        ctx.translate(point.x, point.y + float);
        ctx.rotate(angle);
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        let cursor = -(baseGap * 2.25);
        letters.forEach((letter, index) => {
          const isActive = index === activeIndex;
          const scale = isActive ? 1.26 : 1;
          const letterAdvance = baseGap * (isActive ? 1.26 : 0.96);
          ctx.save();
          ctx.translate(cursor, 0);
          ctx.scale(scale, scale);
          ctx.font = `700 ${mark.size}px ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif`;
          const isNightWord = document.body.classList.contains('night-mode');
          ctx.shadowColor = rgbaFor(index, isActive ? (isNightWord ? 0.40 : 0.22) : (isNightWord ? 0.22 : 0.14), isNightWord ? 44 : 10);
          ctx.shadowBlur = isActive ? (isNightWord ? 12 : 7) : (isNightWord ? 6 : 3);
          ctx.fillStyle = rgbaFor(index, isActive ? (isNightWord ? 0.46 : 0.34) : (isNightWord ? 0.26 : 0.20), isNightWord ? 30 : 6);
          ctx.fillText(letter, 0, 0);
          ctx.shadowBlur = 0;
          ctx.restore();
          cursor += letterAdvance;
        });
        ctx.restore();
      }

      function drawGridWave(time) {
        ctx.clearRect(0, 0, width, height);
        mouse.x += (mouse.tx - mouse.x) * 0.065;
        mouse.y += (mouse.ty - mouse.y) * 0.065;
        active.index += (active.target - active.index) * 0.10;

        const viewX = (mouse.x - 0.5) * 2;
        const viewY = (mouse.y - 0.5) * 2;
        const baseY = height * 0.61 + viewY * 34;
        const skew = viewX * 58;
        const amplitude = Math.max(20, Math.min(42, height * 0.042));
        const gap = Math.max(64, Math.min(92, height * 0.098));
        const now = reduceMotion ? 0 : time * 0.001;
        const isNight = document.body.classList.contains('night-mode');

        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';

        for (let row = -4; row < 11; row += 1) {
          const y0 = baseY + row * gap;
          if (y0 < -120 || y0 > height + 160) continue;
          ctx.beginPath();
          for (let x = -100; x <= width + 100; x += 18) {
            const p = wavePoint(x, row, now, baseY, gap, amplitude, viewX, viewY, skew);
            if (x === -100) ctx.moveTo(p.x, p.y);
            else ctx.lineTo(p.x, p.y);
          }
          const paletteIndex = ((row % palette.length) + palette.length) % palette.length;
          const emphasis = 1 - Math.min(1, Math.abs(active.index - paletteIndex) * 0.42);
          const lineAlpha = isNight ? 0.22 + emphasis * 0.30 : 0.15 + emphasis * 0.24;
          ctx.strokeStyle = rgbaFor(paletteIndex, lineAlpha, isNight ? 44 : 12);
          ctx.lineWidth = (isNight ? 1.35 : 1.2) + emphasis * (isNight ? 2.45 : 2.2);
          ctx.shadowColor = rgbaFor(paletteIndex, isNight ? 0.54 + emphasis * 0.20 : 0.42 + emphasis * 0.18, isNight ? 54 : 18);
          ctx.shadowBlur = isNight ? (emphasis > 0.85 ? 22 : 8 + emphasis * 7) : (emphasis > 0.85 ? 18 : 6 + emphasis * 4);
          ctx.globalAlpha = isNight ? 0.34 + emphasis * 0.36 : 0.44 + emphasis * 0.38;
          ctx.stroke();
          ctx.shadowBlur = 0;
        }
        ctx.globalAlpha = 1;

        ctx.save();
        ctx.lineWidth = 0.85;
        ctx.strokeStyle = isNight ? 'rgba(245, 230, 210, 0.045)' : 'rgba(120, 110, 100, 0.08)';
        for (let col = -1; col < 8; col += 1) {
          const x0 = col * (width / 6) + viewX * 18;
          ctx.beginPath();
          for (let t = 0; t <= 1; t += 0.06) {
            const y = baseY - 190 + t * (height * 0.86);
            const wave = Math.sin(t * 7.5 + now * 0.7 + col * 0.55) * 9;
            const x = x0 + wave + (t - 0.5) * skew * 0.66;
            if (t === 0) ctx.moveTo(x, y);
            else ctx.lineTo(x, y);
          }
          ctx.stroke();
        }
        ctx.restore();

        wordMarks.forEach(mark => {
          drawPrismWord(mark, now, baseY, gap, amplitude, viewX, viewY, skew);
        });

        ctx.save();
        ctx.globalAlpha = isNight ? 0.09 : 0.14;
        ctx.font = '700 50px ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.translate(width * 0.12 + viewX * 12, height * 0.24 + viewY * 10);
        ctx.rotate(-0.14 + viewX * 0.04);
        const letters = ['p','r','i','s','m'];
        let offset = -70;
        letters.forEach((letter, index) => {
          const focusBoost = 1 - Math.min(1, Math.abs(active.index - index) * 0.46);
          ctx.save();
          ctx.translate(offset, 0);
          ctx.scale(1 + focusBoost * 0.14, 1 + focusBoost * 0.14);
          ctx.fillStyle = rgbaFor(index, isNight ? 0.16 + focusBoost * 0.08 : 0.18 + focusBoost * 0.10, isNight ? 32 : 14);
          ctx.fillText(letter, 0, 0);
          ctx.restore();
          offset += 34 + focusBoost * 8;
        });
        ctx.restore();

        const glow = ctx.createRadialGradient(width * mouse.x, height * mouse.y, 0, width * mouse.x, height * mouse.y, Math.max(width, height) * 0.55);
        glow.addColorStop(0, isNight ? 'rgba(255, 248, 226, 0.10)' : 'rgba(255, 255, 255, 0.26)');
        glow.addColorStop(0.28, rgbaFor(Math.round(active.index), isNight ? 0.13 : 0.10, isNight ? 58 : 28));
        glow.addColorStop(0.50, isNight ? 'rgba(255,248,226,0.025)' : 'rgba(255,255,255,0.04)');
        glow.addColorStop(1, 'rgba(255, 255, 255, 0)');
        ctx.fillStyle = glow;
        ctx.fillRect(0, 0, width, height);
      }

      function animateWave(time) {
        drawGridWave(time || 0);
        if (!reduceMotion) frame = window.requestAnimationFrame(animateWave);
      }

      window.addEventListener('resize', resizeWave);
      window.addEventListener('pointermove', event => {
        mouse.tx = event.clientX / Math.max(1, window.innerWidth);
        mouse.ty = event.clientY / Math.max(1, window.innerHeight);
      });
      resizeWave();
      animateWave(0);
    }


    bindPrismLetterInteractions();
    initWaveBackground();
    render();
  </script>
</body>
</html>
